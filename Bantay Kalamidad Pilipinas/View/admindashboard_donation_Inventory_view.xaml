<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_donation_Inventory_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C"
          Margin="0,0,0,10">

        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Inventory"
                   Style="{StaticResource TableH1}"
                   FontSize="18"/>

        <Grid Grid.Row="1"
              Margin="8,0,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="21.241"/>
                <ColumnDefinition Width="148.759"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource Combo1}"
                      VerticalAlignment="Top"
                      SelectedItem="{Binding SelectedInventoryFilter}" Grid.ColumnSpan="2" Margin="0,8,0,0">
                <ComboBoxItem Content="Filter"/>
                <ComboBoxItem Content="All Inventory"/>
                <ComboBoxItem Content="Available"/>
                <ComboBoxItem Content="Expiring Soon"/>
                <ComboBoxItem Content="Low Stock"/>
            </ComboBox>

            <Border Grid.Column="3"
                    Height="28"
                    Background="White"
                    VerticalAlignment="Top" Margin="0,6,0,0">
                <Grid>
                    <TextBox Text="{Binding InventorySearchText}"
                             Style="{StaticResource Searchbox}"/>

                    <TextBlock Text="Search"
                               Style="{StaticResource Search}"
                               Margin="12,0,0,0"/>

                    <Viewbox Width="14"
                             Height="14"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0">
                        <Canvas Width="18" Height="18">
                            <Ellipse Style="{StaticResource Ellipse1}"/>
                            <Path Data="M10,10 L16,16" Style="{StaticResource Path1}"/>
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#D9D9D9"
                Margin="8,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="0.9*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.25*"/>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="1.25*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Inventory ID" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="1" Text="Item" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="2" Text="Donated Item" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="3" Text="Quantity Available" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="4" Text="Expiration Date" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="5" Text="Storage Location" Style="{StaticResource TableSub1}"/>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                Margin="8,0,8,0"
                ClipToBounds="True">
            <DataGrid ItemsSource="{Binding InventoryRecords}"
                      SelectedItem="{Binding SelectedInventoryRecord}"
                      AutoGenerateColumns="False"
                      Style="{StaticResource Table}">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding InventoryId}" Width="1.1*"/>
                    <DataGridTextColumn Binding="{Binding Item}" Width="0.9*"/>
                    <DataGridTextColumn Binding="{Binding DonatedItem}" Width="1.2*"/>
                    <DataGridTextColumn Binding="{Binding QuantityAvailable}" Width="1.25*"/>
                    <DataGridTextColumn Binding="{Binding ExpirationDate}" Width="1.15*"/>
                    <DataGridTextColumn Binding="{Binding StorageLocation}" Width="1.25*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="4"
              Background="#7F7F7F"
              Margin="8,0,8,0"
              Visibility="{Binding ActionButtonsVisibility}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">

                <Button Content="SAVE"
                        Style="{StaticResource CRUDbtn}" 
                        Command="{Binding SaveCommand}"/>

                <Button Content="UPDATE" 
                        Style="{StaticResource CRUDbtn}"  
                        Command="{Binding UpdateCommand}"/>

                <Button Content="DELETE"
                        Style="{StaticResource CRUDbtn}"
                        Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>