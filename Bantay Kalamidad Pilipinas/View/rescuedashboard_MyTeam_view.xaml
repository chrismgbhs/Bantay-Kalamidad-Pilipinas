<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.rescuedashboard_MyTeam_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="My Team"
                   FontSize="18"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"/>

        <Border Grid.Row="1"
                Background="#D9D9D9"
                Margin="0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Volunteer" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Role" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Status" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Contact" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

        </Border>

        <Border Grid.Row="2"
                Background="White"
                Margin="0"
                ClipToBounds="True">

            <DataGrid ItemsSource="{Binding MyTeam}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="None"
                      CanUserAddRows="False"
                      CanUserResizeRows="False"
                      CanUserResizeColumns="False"
                      GridLinesVisibility="None"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F2F2F2"
                      Foreground="Black"
                      BorderThickness="0"
                      RowHeight="28"
                      FontSize="11"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Volunteer}" Width="*"/>
                    <DataGridTextColumn Binding="{Binding Role}" Width="*"/>
                    <DataGridTextColumn Binding="{Binding Status}" Width="*"/>

                    <DataGridTextColumn Width="*">
                        <DataGridTextColumn.Binding>
                            <PriorityBinding>
                                <Binding Path="Contact"/>
                                <Binding Path="ContactNumber"/>
                                <Binding Path="Contact_Number"/>
                                <Binding Path="VolunteerContact"/>
                            </PriorityBinding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>
</UserControl>