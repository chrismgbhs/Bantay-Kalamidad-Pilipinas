<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.rescue_login_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Viewbox Stretch="Uniform">
        <Grid Width="1200" Height="800" Background="White">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,40">

                    <Image Source="/Images/bkp_logo.png"
                           Width="85"
                           Height="85"
                           Margin="0,0,20,0"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Bantay Kalamidad Pilipinas"
                                   FontSize="34"
                                   FontWeight="Black"/>
                        <TextBlock Text="Disaster Response and Relief Coordination System"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                    </StackPanel>

                </StackPanel>

                <Border Width="460"
                        Height="540"
                        BorderBrush="#A30000"
                        BorderThickness="3"
                        CornerRadius="10"
                        Background="White">

                    <Grid>

                        <Button Width="50"
                                Height="50"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="18,14,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding BackCommand}">
                            <TextBlock Text="&#xE72B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Foreground="Black"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>

                        <StackPanel Margin="55,45,55,0">

                            <TextBlock Text="RESCUER SIGN IN"
                                       FontSize="16"
                                       FontWeight="Black"
                                       HorizontalAlignment="Center"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,6,0,40">

                                <TextBlock Text="New to BKP? "
                                           FontSize="12"
                                           Foreground="#777"/>

                                <Button Content="Sign up"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="12"
                                        Cursor="Hand"
                                        Command="{Binding OpenSignupCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}"
                                                       TextDecorations="Underline"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                            </StackPanel>

                            <TextBlock Text="Email Address"
                                       FontSize="13"
                                       Margin="0,0,0,6"/>

                            <TextBox Height="34"
                                     Padding="12,0"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#555"
                                     BorderThickness="1"
                                     Margin="0,0,0,20"
                                     Text="{Binding CurrentUser.Username}"/>

                            <TextBlock Text="Password"
                                       FontSize="13"
                                       Margin="0,0,0,6"/>

                            <PasswordBox 
                                         x:Name="passwordBox" 
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         Height="34"
                                         Padding="12,0"
                                         FontSize="13"
                                         VerticalContentAlignment="Center"
                                         BorderBrush="#555"
                                         BorderThickness="1"
                                         Margin="0,0,0,12"/>

                            <Button Content="Forget password?"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#777"
                                    FontSize="11"
                                    HorizontalAlignment="Left"
                                    Cursor="Hand"
                                    Command="{Binding ForgotPasswordCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   TextDecorations="Underline"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="Sign in"
                                    Height="42"
                                    Background="#A30000"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    FontSize="14"
                                    Margin="0,45,0,35"
                                    Cursor="Hand"
                                    Command="{Binding LoginCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">

                                <Button Width="58" Height="38" Margin="0,0,14,0"
                                        Background="White"
                                        BorderBrush="#D6D6D6"
                                        BorderThickness="1"
                                        Command="{Binding FacebookLoginCommand}">
                                    <Border CornerRadius="19">
                                        <Image Source="/Images/fb_logo.png"
                                               Width="20"/>
                                    </Border>
                                </Button>

                                <Button Width="58" Height="38" Margin="0,0,14,0"
                                        Background="White"
                                        BorderBrush="#D6D6D6"
                                        BorderThickness="1"
                                        Command="{Binding InstagramLoginCommand}">
                                    <Border CornerRadius="19">
                                        <Image Source="/Images/ig_logo.png"
                                               Width="20"/>
                                    </Border>
                                </Button>

                                <Button Width="58" Height="38" Margin="0,0,14,0"
                                        Background="White"
                                        BorderBrush="#D6D6D6"
                                        BorderThickness="1"
                                        Command="{Binding GoogleLoginCommand}">
                                    <Border CornerRadius="19">
                                        <Image Source="/Images/google_logo.png"
                                               Width="20"/>
                                    </Border>
                                </Button>

                                <Button Width="58" Height="38"
                                        Background="White"
                                        BorderBrush="#D6D6D6"
                                        BorderThickness="1"
                                        Command="{Binding XLoginCommand}">
                                    <Border CornerRadius="19">
                                        <Image Source="/Images/x_logo.png"
                                               Width="18"/>
                                    </Border>
                                </Button>

                            </StackPanel>

                        </StackPanel>

                    </Grid>

                </Border>

            </StackPanel>

        </Grid>
    </Viewbox>
</UserControl>