<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.donation_login_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Viewbox Stretch="Uniform">
        <Grid Width="1100" Height="750">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,40,0,20">

                <Image Source="/Images/bkp_logo.png"
                       Width="70"
                       Height="70"
                       Margin="0,0,15,0"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Bantay Kalamidad Pilipinas"
                               FontSize="26"
                               FontWeight="Black"/>
                    <TextBlock Text="Disaster Response and Relief Coordination System"
                               FontSize="18"
                               FontWeight="Bold"/>
                </StackPanel>

            </StackPanel>

            <Grid Grid.Row="1">

                <Border Width="420"
                        Height="500"
                        BorderBrush="#07314E"
                        BorderThickness="3"
                        CornerRadius="10"
                        Background="White"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                    <StackPanel Margin="40">

                        <TextBlock Text="DONOR SIGN IN"
                                   FontSize="16"
                                   FontWeight="Black"
                                   HorizontalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,5,0,30">

                            <TextBlock Text="New to BKP? "
                                       FontSize="12"
                                       Foreground="#777"/>

                            <Button Content="Sign up"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="Black"
                                    FontSize="12"
                                    Cursor="Hand"
                                    Command="{Binding OpenSignupCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   TextDecorations="Underline"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>

                        <TextBlock Text="Email Address"
                                   FontSize="13"/>

                        <TextBox Height="35"
                                 Margin="0,5,0,20"
                                 Padding="10"
                                 Text="{Binding EmailAddress}"/>

                        <TextBlock Text="Password"
                                   FontSize="13"/>

                        <PasswordBox Height="35"
                                     Margin="0,5,0,10"
                                     Padding="10"/>

                        <Button Content="Forget password?"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#777"
                                FontSize="11"
                                HorizontalAlignment="Left"
                                Cursor="Hand"
                                Command="{Binding ForgotPasswordCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               TextDecorations="Underline"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="Log in"
                                Height="40"
                                Margin="0,30,0,30"
                                Background="#07314E"
                                Foreground="White"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Command="{Binding LoginCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <Button Width="55" Height="38" Margin="5"
                                    Background="White"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    Command="{Binding FacebookLoginCommand}">
                                <Image Source="/Images/fb_logo.png" Width="18"/>
                            </Button>

                            <Button Width="55" Height="38" Margin="5"
                                    Background="White"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    Command="{Binding InstagramLoginCommand}">
                                <Image Source="/Images/ig_logo.png" Width="18"/>
                            </Button>

                            <Button Width="55" Height="38" Margin="5"
                                    Background="White"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    Command="{Binding GoogleLoginCommand}">
                                <Image Source="/Images/google_logo.png" Width="18"/>
                            </Button>

                            <Button Width="55" Height="38" Margin="5"
                                    Background="White"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    Command="{Binding XLoginCommand}">
                                <Image Source="/Images/x_logo.png" Width="18"/>
                            </Button>

                        </StackPanel>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>
    </Viewbox>
</UserControl>