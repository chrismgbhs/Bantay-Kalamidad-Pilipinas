<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admin_menu_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Viewbox Stretch="Uniform">
        <Grid Width="1200" Height="800" Background="White">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,45">

                    <Image Source="/Images/bkp_logo.png"
                           Width="85"
                           Height="85"
                           Margin="0,0,20,0"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Bantay Kalamidad Pilipinas"
                                   FontSize="34"
                                   FontWeight="Black"/>
                        <TextBlock Text="Disaster Response and Relief Coordination System"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                    </StackPanel>

                </StackPanel>

                <TextBlock Text="ADMIN MENU"
                           FontSize="24"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,42"/>

                <Button Content="RESCUE"
                        Width="390"
                        Height="70"
                        Background="#E51612"
                        BorderBrush="#8F0707"
                        BorderThickness="4"
                        Foreground="White"
                        FontSize="17"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Command="{Binding OpenAdminRescueDashboardCommand}"
                        Margin="0,0,0,42">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="DONATION"
                        Width="390"
                        Height="70"
                        Background="#246F8F"
                        BorderBrush="#07314E"
                        BorderThickness="4"
                        Foreground="White"
                        FontSize="17"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Command="{Binding OpenAdminDonationDashboardCommand}"
                        Margin="0,0,0,42">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="BACK TO SIGN IN"
                        Width="390"
                        Height="70"
                        Background="#7F7F7F"
                        BorderBrush="#07314E"
                        BorderThickness="4"
                        Foreground="White"
                        FontSize="17"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Command="{Binding BackToSigninCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>

        </Grid>
    </Viewbox>
</UserControl>