<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.donationdashboard_ContactUs_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             VerticalAlignment="Stretch"
             MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ContentControl}}"
             MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ContentControl}}"
             Background="Transparent">

    <Grid Background="#2C2C2C"
          HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
          >

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="116"/>
            <RowDefinition Height="58"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="14,14,14,0">
            <TextBlock Text="Contact Us"
                       FontSize="22"
                       FontWeight="Black"
                       Foreground="White"/>

            <TextBlock Text="Have questions or need assistance? Reach out to us."
                       FontSize="12"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1"
              Margin="14,0,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Full Name:"
                       FontSize="12"
                       FontWeight="Black"
                       Foreground="White"
                       VerticalAlignment="Center"/>

            <TextBox Grid.Column="1"
                     Text="{Binding FullName}"
                     Style="{StaticResource Fillupbox}"/>
        </Grid>

        <Grid Grid.Row="2"
              Margin="14,0,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Email:"
                       FontSize="12"
                       FontWeight="Black"
                       Foreground="White"
                       VerticalAlignment="Center"/>

            <TextBox Grid.Column="1"
                     Text="{Binding Email}"
                     Style="{StaticResource Fillupbox}"/>
        </Grid>

        <Grid Grid.Row="3"
              Margin="14,0,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Subject:"
                       FontSize="12"
                       FontWeight="Black"
                       Foreground="White"
                       VerticalAlignment="Center"/>

            <TextBox Grid.Column="1"
                     Text="{Binding Subject}"
                     Style="{StaticResource Fillupbox}"/>
        </Grid>

        <TextBlock Grid.Row="4"
                   Text="Message:"
                   FontSize="12"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="14,0,0,8"/>

        <TextBox Grid.Row="5"
                 Text="{Binding Message}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="White"
                 Foreground="Black"
                 BorderThickness="0"
                 FontSize="13"
                 Padding="8"
                 Margin="14,0,14,0"/>

        <Button Grid.Row="6"
                Content="Send"
                Width="110"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#8A8A8A"
                Foreground="White"
                FontSize="12"
                FontWeight="Black"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding SendMessageCommand}"/>

    </Grid>
</UserControl>