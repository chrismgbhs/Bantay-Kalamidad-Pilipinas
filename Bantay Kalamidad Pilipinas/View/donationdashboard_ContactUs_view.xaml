<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.donationdashboard_ContactUs_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="76"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="16,14,16,0">
            <TextBlock Text="Contact Us"
                       FontSize="24"
                       FontWeight="Black"
                       Foreground="White"/>

            <TextBlock Text="Have questions or need assistance? Reach out to us."
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="18,0,18,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="105"/>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Full Name:"
                       FontSize="14"
                       FontWeight="Black"
                       Foreground="White"
                       VerticalAlignment="Center"/>

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="3"
                    Height="30">
                <TextBox Text="{Binding FullName}"
                         Background="Transparent"
                         Foreground="White"
                         BorderThickness="0"
                         FontSize="13"
                         Padding="10,0"
                         VerticalContentAlignment="Center"/>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="18,0,18,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="105"/>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Email:"
                       FontSize="14"
                       FontWeight="Black"
                       Foreground="White"
                       VerticalAlignment="Center"/>

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="3"
                    Height="30">
                <TextBox Text="{Binding Email}"
                         Background="Transparent"
                         Foreground="White"
                         BorderThickness="0"
                         FontSize="13"
                         Padding="10,0"
                         VerticalContentAlignment="Center"/>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="18,0,18,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="105"/>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Subject:"
                       FontSize="14"
                       FontWeight="Black"
                       Foreground="White"
                       VerticalAlignment="Center"/>

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="3"
                    Height="30">
                <TextBox Text="{Binding Subject}"
                         Background="Transparent"
                         Foreground="White"
                         BorderThickness="0"
                         FontSize="13"
                         Padding="10,0"
                         VerticalContentAlignment="Center"/>
            </Border>
        </Grid>

        <TextBlock Grid.Row="4"
                   Text="Message:"
                   FontSize="14"
                   FontWeight="Black"
                   Foreground="White"
                   Margin="18,0,0,0"
                   VerticalAlignment="Center"/>

        <Border Grid.Row="5"
                Background="White"
                CornerRadius="3"
                Margin="18,0,18,0">

            <TextBox Text="{Binding Message}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="Transparent"
                     Foreground="White"
                     BorderThickness="0"
                     FontSize="13"
                     Padding="10"/>

        </Border>

        <Button Grid.Row="6"
                Content="Send"
                Width="165"
                Height="38"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#8A8A8A"
                Foreground="White"
                FontSize="14"
                FontWeight="Black"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding SendMessageCommand}">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</UserControl>