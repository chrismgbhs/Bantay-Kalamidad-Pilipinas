<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.rescuedashboard_RescueLocations_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Rescue Locations"
                   FontSize="24"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="14,0,0,0"/>

        <Border Grid.Row="1"
                Background="#D9D9D9"
                Margin="10,0,10,0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Barangay" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="City" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Province" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Evacuation Area" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Rescue status" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

        </Border>

        <Border Grid.Row="2"
                Background="#2C2C2C"
                Margin="10,0,10,10"
                ClipToBounds="True">

            <DataGrid ItemsSource="{Binding RescueLocations}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="None"
                      CanUserAddRows="False"
                      CanUserResizeRows="False"
                      CanUserResizeColumns="False"
                      GridLinesVisibility="None"
                      Background="#2C2C2C"
                      RowBackground="#2C2C2C"
                      AlternatingRowBackground="#343434"
                      Foreground="White"
                      BorderThickness="0"
                      RowHeight="34"
                      FontSize="13"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Barangay}" Width="1.1*"/>
                    <DataGridTextColumn Binding="{Binding City}" Width="1*"/>
                    <DataGridTextColumn Binding="{Binding Province}" Width="1*"/>
                    <DataGridTextColumn Binding="{Binding EvacuationArea}" Width="1.2*"/>
                    <DataGridTextColumn Binding="{Binding RescueStatus}" Width="1*"/>
                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>
</UserControl>