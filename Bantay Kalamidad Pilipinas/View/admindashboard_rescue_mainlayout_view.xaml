<Window x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_rescue_mainlayout_view"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard - Rescue"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="CanResize">

    <Viewbox Stretch="Uniform">
        <Grid Width="1100" Height="750" Background="White">

            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="62"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="70,28,70,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Images/bkp_logo.png"
                           Width="70"
                           Height="70"
                           Margin="0,0,16,0"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Bantay Kalamidad Pilipinas"
                                   FontSize="24"
                                   FontWeight="Black"/>
                        <TextBlock Text="Disaster Response and Relief Coordination System"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Column="1"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="Admin Profile"
                                   FontSize="17"
                                   FontWeight="Black"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,0,8"/>

                        <Button Content="Logout"
                                Width="150"
                                Height="32"
                                Background="#7F7F7F"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding LogoutCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="👤"
                               FontSize="34"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Grid>

            <Border Grid.Row="1"
                    Height="50"
                    Background="#A30000"
                    Margin="85,0,85,0"
                    VerticalAlignment="Center">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Rescuers"
                            Background="#A30000"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ShowRescuersCommand}"/>

                    <Button Grid.Column="1"
                            Content="Disaster Events"
                            Background="#A30000"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ShowDisasterEventsCommand}"/>

                    <Button Grid.Column="2"
                            Content="Operations"
                            Background="#A30000"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ShowOperationsCommand}"/>

                    <Button Grid.Column="3"
                            Content="Assignments"
                            Background="#A30000"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ShowAssignmentsCommand}"/>

                    <Button Grid.Column="4"
                            Content="Teams"
                            Background="#A30000"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ShowTeamsCommand}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="85,12,85,45">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="155"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#A30000"
                        CornerRadius="8"
                        Padding="14">

                    <StackPanel>
                        <TextBlock Text="{Binding SelectedRescueModuleTitle, FallbackValue=Rescuers}"
                                   Foreground="White"
                                   FontSize="15"
                                   FontWeight="Black"
                                   Margin="0,0,0,18"/>

                        <Button Content="+ Add"
                                Height="32"
                                Background="#B81717"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding AddModeCommand}"
                                Margin="0,0,0,10"/>

                        <Button Content="Manage"
                                Height="32"
                                Background="#B81717"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding ManageModeCommand}"
                                Margin="0,0,0,10"/>

                        <Button Content="View"
                                Height="32"
                                Background="#B81717"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding ViewModeCommand}"/>

                        <Border Background="#8D0000"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,25,0,0">
                            <StackPanel>
                                <TextBlock Text="Current Mode"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding CurrentMode, FallbackValue=View}"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="Black"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Border>

                <Border Grid.Column="2"
                        Background="#F6F6F6"
                        CornerRadius="10"
                        BorderBrush="#D9D9D9"
                        BorderThickness="1"
                        Padding="16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="48"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding SelectedRescueModuleTitle, FallbackValue=Rescuers}"
                                   FontSize="24"
                                   FontWeight="Black"
                                   Foreground="#252525"
                                   Margin="0,0,0,12"/>

                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Height="36"
                                      FontWeight="Bold"
                                      SelectedItem="{Binding SelectedFilter}">
                                <ComboBoxItem Content="Filter"/>
                                <ComboBoxItem Content="Active"/>
                                <ComboBoxItem Content="Pending"/>
                                <ComboBoxItem Content="Completed"/>
                            </ComboBox>

                            <Border Grid.Column="2"
                                    Background="White"
                                    BorderBrush="#D0D0D0"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Height="36">
                                <TextBox Text="{Binding SearchText}"
                                         BorderThickness="0"
                                         Padding="12,0"
                                         VerticalContentAlignment="Center"
                                         FontSize="13"/>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="#2C2C2C"
                                CornerRadius="6"
                                ClipToBounds="True">

                            <DataGrid ItemsSource="{Binding RescueAdminRecords}"
                                      SelectedItem="{Binding SelectedRescueAdminRecord}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      Background="#2C2C2C"
                                      RowBackground="#353535"
                                      AlternatingRowBackground="#303030"
                                      Foreground="White"
                                      BorderThickness="0"
                                      ColumnHeaderHeight="34"
                                      RowHeight="34"
                                      FontSize="13">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#D9D9D9"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{Binding FirstColumnHeader, FallbackValue=Rescuer ID}"
                                                        Binding="{Binding PrimaryId}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="{Binding SecondColumnHeader, FallbackValue=Location}"
                                                        Binding="{Binding Location}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="{Binding ThirdColumnHeader, FallbackValue=Date Started}"
                                                        Binding="{Binding DateStarted}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="{Binding FourthColumnHeader, FallbackValue=Status}"
                                                        Binding="{Binding Status}"
                                                        Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                        </Border>

                        <Grid Grid.Row="3">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">

                                <Button Content="SAVE"
                                        Width="90"
                                        Height="32"
                                        Background="#7F7F7F"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{Binding SaveCommand}"
                                        Visibility="{Binding ActionButtonsVisibility}"
                                        Margin="0,0,10,0"/>

                                <Button Content="UPDATE"
                                        Width="90"
                                        Height="32"
                                        Background="#7F7F7F"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{Binding UpdateCommand}"
                                        Visibility="{Binding ActionButtonsVisibility}"
                                        Margin="0,0,10,0"/>

                                <Button Content="DELETE"
                                        Width="90"
                                        Height="32"
                                        Background="#7F7F7F"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{Binding DeleteCommand}"
                                        Visibility="{Binding ActionButtonsVisibility}"/>
                            </StackPanel>
                        </Grid>

                    </Grid>

                </Border>
            </Grid>

        </Grid>
    </Viewbox>
</Window>