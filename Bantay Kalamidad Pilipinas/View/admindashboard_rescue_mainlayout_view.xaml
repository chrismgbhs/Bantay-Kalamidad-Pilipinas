<Window x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_rescue_mainlayout_view"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard - Rescue"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="CanResize">

    <Viewbox Stretch="Uniform">
        <Grid Width="1100" Height="750" Background="White">

            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="62"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="70,28,70,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Images/bkp_logo.png"
                           Width="70"
                           Height="70"
                           Margin="0,0,16,0"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Bantay Kalamidad Pilipinas"
                                   FontSize="24"
                                   FontWeight="Black"/>
                        <TextBlock Text="Disaster Response and Relief Coordination System"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Column="1"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="Admin Profile"
                                   FontSize="17"
                                   FontWeight="Black"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,0,8"/>

                        <Button Content="Logout"
                                Width="150"
                                Height="32"
                                Background="#7F7F7F"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding LogoutCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="👤"
                               FontSize="34"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Grid>

            <Border Grid.Row="1"
                    Height="50"
                    Background="#A30000"
                    Margin="85,0,85,0"
                    VerticalAlignment="Center">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Rescuers"
                            Background="#A30000"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ShowRescuersCommand}"/>

                    <Button Grid.Column="1"
                            Content="Disaster Events"
                            Background="#A30000"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ShowDisasterEventsCommand}"/>

                    <Button Grid.Column="2"
                            Content="Operations"
                            Background="#A30000"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ShowOperationsCommand}"/>

                    <Button Grid.Column="3"
                            Content="Assignments"
                            Background="#A30000"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ShowAssignmentsCommand}"/>

                    <Button Grid.Column="4"
                            Content="Teams"
                            Background="#A30000"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ShowTeamsCommand}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="85,12,85,45">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="155"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#A30000"
                        CornerRadius="8"
                        Padding="14">

                    <StackPanel>
                        <TextBlock Text="{Binding SelectedRescueModuleTitle}"
                                   Foreground="White"
                                   FontSize="15"
                                   FontWeight="Black"
                                   Margin="0,0,0,18"/>

                        <Button Content="+ Add"
                                Height="32"
                                Background="#B81717"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding AddModeCommand}"
                                Margin="0,0,0,10"/>

                        <Button Content="Manage"
                                Height="32"
                                Background="#B81717"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding ManageModeCommand}"
                                Margin="0,0,0,10"/>

                        <Button Content="View"
                                Height="32"
                                Background="#B81717"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding ViewModeCommand}"/>

                        <Border Background="#8D0000"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,25,0,0">
                            <StackPanel>
                                <TextBlock Text="Current Mode"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Margin="0,0,0,5"/>

                                <TextBlock Text="{Binding CurrentMode, FallbackValue=View}"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="Black"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Border>

                <Border Grid.Column="2"
                        Background="#F6F6F6"
                        CornerRadius="10"
                        BorderBrush="#D9D9D9"
                        BorderThickness="1"
                        Padding="16">

                    <ContentControl Content="{Binding CurrentAdminRescueView}">
                        <ContentControl.Template>
                            <ControlTemplate TargetType="ContentControl">
                                <Border Background="White"
                                        CornerRadius="10"
                                        BorderBrush="#DDDDDD"
                                        BorderThickness="1">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </ContentControl.Template>
                    </ContentControl>

                </Border>
            </Grid>

        </Grid>
    </Viewbox>
</Window>