<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admin_login_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Bantay_Kalamidad_Pilipinas.ViewModel"
             Background="White">

    <UserControl.Resources>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Gray"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="1200" Height="800" Background="White">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,52">

                    <Image Source="/Images/bkp_logo.png"
                           Width="85"
                           Height="85"
                           Margin="0,0,20,0"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource OrgName}"/>
                        <TextBlock Style="{StaticResource SystemName}"/>
                    </StackPanel>

                </StackPanel>

                <Border Style="{StaticResource LoginBorder}"
                        BorderBrush="{StaticResource AdminSecond}">

                    <Grid>

                        <Button Style="{StaticResource Arrow}"
                                Margin="20,18,0,0"
                                Command="{Binding BackCommand}">
                            <TextBlock Text="&#xE72B;"
                                       Style="{StaticResource ArrowText}"/>
                        </Button>

                        <StackPanel Margin="55,48,55,0">

                            <TextBlock Text="ADMIN SIGN IN"
                                       Style="{StaticResource LoginHeader}"
                                       Margin="0,0,0,58"/>

                            <TextBlock Text="Username"
                                       Style="{StaticResource LoginSub}"
                                       Margin="0,0,0,6"/>

                            <TextBox Text="{Binding CurrentUser.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource RoundedTextBoxStyle}"
                                     Margin="0,0,0,18"/>

                            <TextBlock Text="Password"
                                       Style="{StaticResource LoginSub}"
                                       Margin="0,0,0,6"/>

                            <PasswordBox Style="{StaticResource Passbox}"
                                         Margin="0,0,0,10"
                                         vm:PasswordBoxHelper.BoundPassword="{Binding CurrentUser.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <Button Content="Forget password?"
                                    Style="{StaticResource ForgetPassbtn}"
                                    Command="{Binding ForgotPasswordCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   TextDecorations="Underline"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="Sign in"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,48,0,0"
                                    Command="{Binding LoginCommand}"/>

           
                        </StackPanel>

                    </Grid>

                </Border>

            </StackPanel>

        </Grid>
    </Viewbox>
</UserControl>