<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admin_login_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Viewbox Stretch="Uniform">
        <Grid Width="1100" Height="750">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,85,0,30">

                <Image Source="/Images/bkp_logo.png"
                       Width="75"
                       Height="75"
                       Margin="0,0,18,0"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Bantay Kalamidad Pilipinas"
                               FontSize="28"
                               FontWeight="Black"/>
                    <TextBlock Text="Disaster Response and Relief Coordination System"
                               FontSize="20"
                               FontWeight="Bold"/>
                </StackPanel>

            </StackPanel>

            <Grid Grid.Row="1">

                <Border Width="420"
                        Height="470"
                        BorderBrush="#7F7F7F"
                        BorderThickness="3"
                        CornerRadius="10"
                        Background="White"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,10,0,0">

                    <StackPanel Margin="45,35,45,0">

                        <TextBlock Text="ADMIN SIGN IN"
                                   FontSize="16"
                                   FontWeight="Black"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,45"/>

                        <TextBlock Text="Username"
                                   FontSize="13"/>

                        <TextBox Height="35"
                                 Margin="0,5,0,20"
                                 Padding="10"
                                 Text="{Binding Username}"/>

                        <TextBlock Text="Password"
                                   FontSize="13"/>

                        <PasswordBox Height="35"
                                     Margin="0,5,0,10"
                                     Padding="10"/>

                        <Button Content="Forget password?"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#777"
                                FontSize="11"
                                HorizontalAlignment="Left"
                                Cursor="Hand"
                                Command="{Binding ForgotPasswordCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               TextDecorations="Underline"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="Log in"
                                Height="40"
                                Margin="0,45,0,0"
                                Background="#7F7F7F"
                                Foreground="White"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Command="{Binding LoginCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>
    </Viewbox>
</UserControl>