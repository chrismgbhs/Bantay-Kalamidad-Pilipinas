<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_rescue_Assignments_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C" Margin="0,0,0,10">

        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Assignments"
                   FontSize="18"
                   Style="{StaticResource TableH1}"/>

        <Grid Grid.Row="1" Margin="8,0,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource Combo1}"
                      VerticalAlignment="Bottom"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding SelectedAssignmentFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ComboBoxItem Content="All Assignments"/>
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="Pending"/>
                <ComboBoxItem Content="Completed"/>
            </ComboBox>

            <Border Grid.Column="2" Height="28" Background="White" VerticalAlignment="Bottom">
                <Grid>
                    <TextBox Text="{Binding AssignmentSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Searchbox}"/>
                    <TextBlock Text="Search" Style="{StaticResource Search}"/>
                    <Viewbox Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Canvas Width="18" Height="18">
                            <Ellipse Style="{StaticResource Ellipse1}"/>
                            <Path Data="M10,10 L16,16" Style="{StaticResource Path1}"/>
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#D9D9D9" Margin="8,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Assignment ID" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="1" Text="Operation" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="2" Text="Rescuer Name" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="3" Text="Role" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="4" Text="Status" Style="{StaticResource TableSub1}"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="White" Margin="8,0,8,0" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Assignments}"
                      SelectedItem="{Binding SelectedAssignment, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="None"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="{Binding IsTableReadOnly}"
                      Style="{StaticResource Table}">
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding AssignmentId}" Width="1.1*" IsReadOnly="True"/>
                    <!-- Operation ID stored but selected via dropdown — not typed -->
                    <DataGridTextColumn Binding="{Binding Operation}" Width="1*" IsReadOnly="True"/>
                    <!-- Rescuer selected via dropdown — not typed -->
                    <DataGridTextColumn Binding="{Binding RescuerName}" Width="1.3*" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding Role, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1*"/>
                    <DataGridTextColumn Binding="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Dropdown panel: visible only in Add/Manage mode -->
        <Border Grid.Row="4"
                Background="#3A3A3A"
                Padding="8,6"
                Visibility="{Binding DropdownPanelVisibility}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <TextBlock Text="Select Operation" Foreground="White" FontSize="11" Margin="0,0,0,2"/>
                    <ComboBox ItemsSource="{Binding AvailableOperations}"
                              SelectedItem="{Binding SelectedOperationDropdown, Mode=TwoWay}"
                              DisplayMemberPath="Display"
                              Background="White"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Select Rescuer" Foreground="White" FontSize="11" Margin="0,0,0,2"/>
                    <ComboBox ItemsSource="{Binding AvailableRescuers}"
                              SelectedItem="{Binding SelectedRescuerDropdown, Mode=TwoWay}"
                              DisplayMemberPath="Display"
                              Background="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="5"
              Background="#7F7F7F"
              Margin="8,0,8,0"
              Visibility="{Binding ActionButtonsVisibility}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">
                <Button Content="SAVE" Style="{StaticResource CRUDbtn}" Command="{Binding SaveCommand}"/>
                <Button Content="UPDATE" Style="{StaticResource CRUDbtn}" Command="{Binding UpdateCommand}"/>
                <Button Content="DELETE" Style="{StaticResource CRUDbtn}" Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>