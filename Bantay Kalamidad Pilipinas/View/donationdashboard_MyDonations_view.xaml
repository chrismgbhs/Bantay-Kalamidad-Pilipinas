<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.donationdashboard_MakeAPledge_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="118"/>
            <RowDefinition Height="52"/>
            <RowDefinition Height="82"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Make a Pledge"
                   FontSize="24"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="16,0,0,0"/>

        <Grid Grid.Row="1" Margin="16,0,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Event:"
                       FontSize="15"
                       FontWeight="Black"
                       Foreground="White"
                       VerticalAlignment="Center"/>

            <ComboBox Grid.Column="1"
                      Height="32"
                      Background="#D9D9D9"
                      Foreground="Black"
                      FontSize="13"
                      BorderThickness="0"
                      Padding="10,0"
                      ItemsSource="{Binding DisasterEvents}"
                      SelectedItem="{Binding SelectedDisasterEvent}"/>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="Items:"
                   FontSize="15"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="16,0,0,0"/>

        <Grid Grid.Row="3" Margin="16,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#D9D9D9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Item Name" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Quantity" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Unit" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Remove" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#2C2C2C"
                    ClipToBounds="True">

                <DataGrid ItemsSource="{Binding PledgeItems}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="None"
                          CanUserAddRows="False"
                          CanUserResizeRows="False"
                          CanUserResizeColumns="False"
                          GridLinesVisibility="None"
                          Background="#2C2C2C"
                          RowBackground="#2C2C2C"
                          AlternatingRowBackground="#343434"
                          Foreground="White"
                          BorderThickness="0"
                          RowHeight="34"
                          FontSize="13"
                          Height="84"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding ItemName}" Width="2*"/>
                        <DataGridTextColumn Binding="{Binding Quantity}" Width="1.2*"/>
                        <DataGridTextColumn Binding="{Binding Unit}" Width="1.2*"/>

                        <DataGridTemplateColumn Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Remove"
                                            Width="70"
                                            Height="24"
                                            Background="#D9D9D9"
                                            Foreground="Black"
                                            FontSize="11"
                                            FontWeight="Bold"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.RemovePledgeItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                </DataGrid>

            </Border>
        </Grid>

        <Grid Grid.Row="4" Margin="16,10,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="170"/>
            </Grid.ColumnDefinitions>

            <Button Content="+ Add Item"
                    Width="110"
                    Height="34"
                    Background="#D9D9D9"
                    Foreground="Black"
                    FontSize="13"
                    FontWeight="Black"
                    BorderThickness="0"
                    Cursor="Hand"
                    Command="{Binding AddPledgeItemCommand}"/>

            <TextBlock Grid.Column="2"
                       Text="Expected Delivery Date:"
                       FontSize="14"
                       FontWeight="Black"
                       Foreground="White"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="0,0,8,0"/>

            <DatePicker Grid.Column="3"
                        Height="32"
                        FontSize="13"
                        SelectedDate="{Binding ExpectedDeliveryDate}"/>
        </Grid>

        <Grid Grid.Row="5" Margin="16,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Notes (optional):"
                       FontSize="15"
                       FontWeight="Black"
                       Foreground="White"
                       VerticalAlignment="Center"/>

            <TextBox Grid.Row="1"
                     Text="{Binding PledgeNotes}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="#D9D9D9"
                     Foreground="Black"
                     BorderThickness="0"
                     FontSize="13"
                     Padding="10"/>
        </Grid>

        <Button Grid.Row="6"
                Content="Submit"
                Width="110"
                Height="34"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#D9D9D9"
                Foreground="Black"
                FontSize="14"
                FontWeight="Black"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding SubmitPledgeCommand}"/>

    </Grid>
</UserControl>