<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.donationdashboard_Pickup_Delivery_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             VerticalAlignment="Stretch"
             MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ContentControl}}"
             MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ContentControl}}"
             Background="Transparent">

    <Grid Background="#2C2C2C"
          HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch">

        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="22"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="22"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Pickup &amp; Delivery"
                   FontSize="18"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"/>

        <TextBlock Grid.Row="1"
                   Text="PICKUP SCHEDULE"
                   FontSize="11"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"/>

        <Grid Grid.Row="2"
              Margin="8,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#D9D9D9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.3*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Donation ID" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Pickup Date" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Status" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Item/s" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="White"
                    ClipToBounds="True">
                <DataGrid ItemsSource="{Binding PickupSchedules}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="None"
                          CanUserAddRows="False"
                          CanUserResizeRows="False"
                          CanUserResizeColumns="False"
                          GridLinesVisibility="None"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#F2F2F2"
                          Foreground="Black"
                          BorderThickness="0"
                          RowHeight="28"
                          FontSize="11"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding DonationId}" Width="1.1*"/>
                        <DataGridTextColumn Binding="{Binding PickupDate}" Width="1.3*"/>
                        <DataGridTextColumn Binding="{Binding Status}" Width="1.2*"/>
                        <DataGridTextColumn Width="1.2*">
                            <DataGridTextColumn.Binding>
                                <PriorityBinding>
                                    <Binding Path="Items"/>
                                    <Binding Path="ItemNames"/>
                                    <Binding Path="ItemName"/>
                                    <Binding Path="DonationItems"/>
                                    <Binding Path="DonatedItems"/>
                                </PriorityBinding>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="4"
                   Text="DELIVERY STATUS"
                   FontSize="11"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"/>

        <Grid Grid.Row="5"
              Margin="8,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#D9D9D9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.3*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Donation ID" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Delivery Date" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Status" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Item/s" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="White"
                    ClipToBounds="True">
                <DataGrid ItemsSource="{Binding DeliveryStatuses}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="None"
                          CanUserAddRows="False"
                          CanUserResizeRows="False"
                          CanUserResizeColumns="False"
                          GridLinesVisibility="None"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#F2F2F2"
                          Foreground="Black"
                          BorderThickness="0"
                          RowHeight="28"
                          FontSize="11"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding DonationId}" Width="1.1*"/>
                        <DataGridTextColumn Binding="{Binding DeliveryDate}" Width="1.3*"/>
                        <DataGridTextColumn Binding="{Binding Status}" Width="1.2*"/>
                        <DataGridTextColumn Width="1.2*">
                            <DataGridTextColumn.Binding>
                                <PriorityBinding>
                                    <Binding Path="Items"/>
                                    <Binding Path="ItemNames"/>
                                    <Binding Path="ItemName"/>
                                    <Binding Path="DonationItems"/>
                                    <Binding Path="DonatedItems"/>
                                </PriorityBinding>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

    </Grid>
</UserControl>