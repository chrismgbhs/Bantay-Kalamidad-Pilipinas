<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.donationdashboard_Pickup_Delivery_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Pickup &amp; Delivery"
                   FontSize="24"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="14,0,0,0"/>

        <TextBlock Grid.Row="1"
                   Text="PICKUP SCHEDULE"
                   FontSize="20"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="14,0,0,0"/>

        <Grid Grid.Row="2" Margin="14,0,14,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#D9D9D9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Donation ID" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Pickup Date" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Status" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#2C2C2C"
                    ClipToBounds="True">

                <DataGrid ItemsSource="{Binding PickupSchedules}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="None"
                          CanUserAddRows="False"
                          CanUserResizeRows="False"
                          CanUserResizeColumns="False"
                          GridLinesVisibility="None"
                          Background="#2C2C2C"
                          RowBackground="#2C2C2C"
                          AlternatingRowBackground="#343434"
                          Foreground="White"
                          BorderThickness="0"
                          RowHeight="32"
                          FontSize="13"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding DonationId}" Width="*"/>
                        <DataGridTextColumn Binding="{Binding PickupDate}" Width="*"/>
                        <DataGridTextColumn Binding="{Binding Status}" Width="*"/>
                    </DataGrid.Columns>

                </DataGrid>

            </Border>
        </Grid>

        <TextBlock Grid.Row="4"
                   Text="DELIVERY STATUS"
                   FontSize="20"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="14,0,0,0"/>

        <Grid Grid.Row="5" Margin="14,0,14,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#D9D9D9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Donation ID" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Delivery Date" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Status" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#2C2C2C"
                    ClipToBounds="True">

                <DataGrid ItemsSource="{Binding DeliveryStatuses}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="None"
                          CanUserAddRows="False"
                          CanUserResizeRows="False"
                          CanUserResizeColumns="False"
                          GridLinesVisibility="None"
                          Background="#2C2C2C"
                          RowBackground="#2C2C2C"
                          AlternatingRowBackground="#343434"
                          Foreground="White"
                          BorderThickness="0"
                          RowHeight="32"
                          FontSize="13"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding DonationId}" Width="*"/>
                        <DataGridTextColumn Binding="{Binding DeliveryDate}" Width="*"/>
                        <DataGridTextColumn Binding="{Binding Status}" Width="*"/>
                    </DataGrid.Columns>

                </DataGrid>

            </Border>
        </Grid>

    </Grid>
</UserControl>