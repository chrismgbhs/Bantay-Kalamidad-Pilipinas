<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.donationdashboard_MakeAPledge_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
                          VerticalAlignment="Stretch"
             MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ContentControl}}"
             MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ContentControl}}"
             Background="Transparent">

    <UserControl.Resources>
        <x:Array x:Key="QuantityOptions" Type="{x:Type sys:Int32}">
            <sys:Int32>1</sys:Int32>
            <sys:Int32>5</sys:Int32>
            <sys:Int32>10</sys:Int32>
            <sys:Int32>25</sys:Int32>
            <sys:Int32>50</sys:Int32>
            <sys:Int32>100</sys:Int32>
            <sys:Int32>250</sys:Int32>
            <sys:Int32>500</sys:Int32>
        </x:Array>

        <x:Array x:Key="UnitOptions" Type="{x:Type sys:String}">
            <sys:String>pcs</sys:String>
            <sys:String>packs</sys:String>
            <sys:String>boxes</sys:String>
            <sys:String>bottles</sys:String>
            <sys:String>cans</sys:String>
            <sys:String>kg</sys:String>
            <sys:String>sacks</sys:String>
            <sys:String>sets</sys:String>
        </x:Array>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#D9D9D9"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#2C2C2C"
          HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
          >

        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Make a Pledge"
                   FontSize="22"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="10,0,0,0"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">
            <TextBlock Text="Event:"
                       FontSize="13"
                       FontWeight="Black"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0"/>

            <ComboBox Width="185"
                      Height="24"
                      Background="#D9D9D9"
                      Foreground="Black"
                      FontSize="12"
                      FontWeight="Bold"
                      BorderThickness="0"
                      Padding="6,0"
                      ItemsSource="{Binding DisasterEvents}"
                      SelectedItem="{Binding SelectedDisasterEvent}"
                      DisplayMemberPath="Event_Name"/>

            <TextBlock Text="Select Disaster Event"
                       FontSize="12"
                       FontWeight="Black"
                       Foreground="Black"
                       VerticalAlignment="Center"
                       Margin="-180,0,0,0"
                       IsHitTestVisible="False"/>
        </StackPanel>

        <Border Grid.Row="2"
                Background="#D9D9D9"
                Margin="8,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Item Name" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Quantity ▼" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Unit ▼" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Remove" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                Margin="8,0,8,0"
                ClipToBounds="True">

            <DataGrid ItemsSource="{Binding PledgeItems}"
                      SelectedItem="{Binding SelectedPledge, UpdateSourceTrigger=PropertyChanged}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="None"
                      CanUserAddRows="False"
                      CanUserResizeRows="False"
                      CanUserResizeColumns="False"
                      GridLinesVisibility="None"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F2F2F2"
                      Foreground="Black"
                      BorderThickness="0"
                      RowHeight="34"
                      FontSize="13"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding ItemName}" Width="2*"/>

                    <DataGridComboBoxColumn Width="1.3*"
                                            ItemsSource="{StaticResource QuantityOptions}"
                                            SelectedItemBinding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                    <DataGridComboBoxColumn Width="1.3*"
                                            ItemsSource="{StaticResource UnitOptions}"
                                            SelectedItemBinding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"/>

                    <DataGridTemplateColumn Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Remove"
                                        Height="24"
                                        Width="70"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding DataContext.RemovePledgeItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

        </Border>

        <Grid Grid.Row="4"
              Margin="8,0,8,8"
              Background="#2C2C2C">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="+ Add Item"
                    Width="96"
                    Height="30"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding AddItemCommand}"/>

            <TextBlock Grid.Column="2"
                       Text="Expected Delivery Date:"
                       FontSize="12"
                       FontWeight="Black"
                       Foreground="White"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,6,8"/>

            <DatePicker Grid.Column="3"
                        Height="26"
                        VerticalAlignment="Bottom"
                        FontSize="12"
                        SelectedDate="{Binding ExpectedDeliveryDate}"/>

            <Button Grid.Column="4"
                    Content="Submit"
                    Width="92"
                    Height="30"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding SubmitPledgeCommand}"/>
        </Grid>

    </Grid>
</UserControl>