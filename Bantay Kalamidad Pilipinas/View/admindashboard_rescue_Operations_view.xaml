<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_rescue_Operations_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="54"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Operations"
                   FontSize="24"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="14,0,0,0"/>

        <Grid Grid.Row="1" Margin="14,0,14,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Height="36"
                      Background="#D9D9D9"
                      Foreground="Black"
                      FontSize="13"
                      FontWeight="Bold"
                      BorderThickness="0"
                      Padding="12,0"
                      SelectedItem="{Binding SelectedOperationFilter}">
                <ComboBoxItem Content="All Operations"/>
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="Pending"/>
                <ComboBoxItem Content="Completed"/>
            </ComboBox>

            <Border Grid.Column="2"
                    Height="36"
                    Background="#D9D9D9"
                    CornerRadius="3">

                <Grid>
                    <TextBox Text="{Binding OperationSearchText}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="13"
                             FontWeight="Bold"
                             Foreground="Black"
                             Padding="12,0,36,0"
                             VerticalContentAlignment="Center"/>

                    <TextBlock Text="🔍"
                               FontSize="15"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                </Grid>

            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#D9D9D9"
                Margin="14,0,14,0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Operation ID" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Event" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Location" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Date Started" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Status" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

        </Border>

        <Border Grid.Row="3"
                Background="#2C2C2C"
                Margin="14,0,14,0"
                ClipToBounds="True">

            <DataGrid ItemsSource="{Binding Operations}"
                      SelectedItem="{Binding SelectedOperation}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="None"
                      CanUserAddRows="False"
                      CanUserResizeRows="False"
                      CanUserResizeColumns="False"
                      GridLinesVisibility="None"
                      Background="#2C2C2C"
                      RowBackground="#2C2C2C"
                      AlternatingRowBackground="#343434"
                      Foreground="White"
                      BorderThickness="0"
                      RowHeight="34"
                      FontSize="13"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding OperationId}" Width="1.1*"/>
                    <DataGridTextColumn Binding="{Binding Event}" Width="1*"/>
                    <DataGridTextColumn Binding="{Binding Location}" Width="1.1*"/>
                    <DataGridTextColumn Binding="{Binding DateStarted}" Width="1.2*"/>
                    <DataGridTextColumn Binding="{Binding Status}" Width="1*"/>
                </DataGrid.Columns>

            </DataGrid>

        </Border>

        <Grid Grid.Row="4"
              Background="#7F7F7F"
              Visibility="{Binding ActionButtonsVisibility}">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0">

                <Button Content="SAVE"
                        Width="80"
                        Height="28"
                        Background="Transparent"
                        Foreground="Black"
                        FontSize="12"
                        FontWeight="Black"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding SaveCommand}"/>

                <Button Content="UPDATE"
                        Width="90"
                        Height="28"
                        Background="Transparent"
                        Foreground="Black"
                        FontSize="12"
                        FontWeight="Black"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding UpdateCommand}"/>

                <Button Content="DELETE"
                        Width="80"
                        Height="28"
                        Background="Transparent"
                        Foreground="Black"
                        FontSize="12"
                        FontWeight="Black"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding DeleteCommand}"/>

            </StackPanel>

        </Grid>

    </Grid>
</UserControl>