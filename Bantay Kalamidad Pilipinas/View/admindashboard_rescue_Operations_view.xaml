<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_rescue_Operations_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="8"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Operations"
                   FontSize="18"
                   Style="{StaticResource TableH1}"/>

        <Grid Grid.Row="1"
              Margin="8,0,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource Combo1}"
                      VerticalAlignment="Bottom"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding SelectedOperationFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ComboBoxItem Content="All Operations"/>
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="Pending"/>
                <ComboBoxItem Content="Completed"/>
            </ComboBox>

            <Border Grid.Column="2"
                    Height="28"
                    Background="White"
                    VerticalAlignment="Bottom">
                <Grid>
                    <TextBox Text="{Binding OperationSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Searchbox}"/>
                    <TextBlock Text="Search" Style="{StaticResource Search}"/>
                    <Viewbox Width="15" Height="15" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Canvas Width="18" Height="18">
                            <Ellipse Style="{StaticResource Ellipse1}"/>
                            <Path Data="M10,10 L16,16" Style="{StaticResource Path1}"/>
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#D9D9D9" Margin="8,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Operation ID" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="1" Text="Event" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="2" Text="Location" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="3" Text="Date Started" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="4" Text="Status" Style="{StaticResource TableSub1}"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="White" Margin="8,0,8,0" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Operations}"
                      SelectedItem="{Binding SelectedOperation, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="None"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="{Binding IsTableReadOnly}"
                      Style="{StaticResource Table}">
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>

                    <!-- Operation ID: auto-generated, read-only -->
                    <DataGridTextColumn Binding="{Binding OperationId}" Width="1.1*" IsReadOnly="True"/>

                    <!-- Event: ComboBox in cell, shows Event_Name, stores EventId -->
                    <DataGridTemplateColumn Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Event}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableEvents,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          SelectedItem="{Binding DataContext.SelectedEventDropdown,
                                              RelativeSource={RelativeSource AncestorType=DataGrid},
                                              Mode=TwoWay}"
                                          DisplayMemberPath="Display"
                                          BorderThickness="0"
                                          Background="White"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Location: ComboBox in cell -->
                    <DataGridTemplateColumn Width="1.1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Location}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding DataContext.AvailableLocations,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              SelectedItem="{Binding DataContext.SelectedLocationDropdown,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid},
                                                  Mode=TwoWay}"
                                              DisplayMemberPath="Display"
                                              BorderThickness="0"
                                              Background="White"/>
                                    <Button Grid.Column="1"
                                            Content="+"
                                            Width="22"
                                            Command="{Binding DataContext.AddNewLocationCommand,
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            ToolTip="Add new location"
                                            Padding="0"
                                            FontWeight="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Date Started: DatePicker in cell -->
                    <DataGridTemplateColumn Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DateStarted, StringFormat=yyyy-MM-dd}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding DateStarted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            BorderThickness="0"
                                            Background="Transparent"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status: typed -->
                    <DataGridTextColumn Binding="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1*"/>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- The separate dropdown panel is no longer needed since selection
             is now done inside the table cells above. Kept collapsed so the
             DropdownPanelVisibility binding doesn't error. -->
        <Border Grid.Row="4"
                Background="#3A3A3A"
                Padding="8,6"
                Visibility="Collapsed"/>

        <Grid Grid.Row="5"
              Background="#7F7F7F"
              Margin="8,0,8,0"
              Visibility="{Binding ActionButtonsVisibility}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">
                <Button Content="SAVE" Style="{StaticResource CRUDbtn}" Command="{Binding SaveCommand}"/>
                <Button Content="UPDATE" Style="{StaticResource CRUDbtn}" Command="{Binding UpdateCommand}"/>
                <Button Content="DELETE" Style="{StaticResource CRUDbtn}" Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>