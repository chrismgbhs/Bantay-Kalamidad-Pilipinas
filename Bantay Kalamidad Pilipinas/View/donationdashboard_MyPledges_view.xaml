<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.donationdashboard_MyPledges_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="54"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="My Pledges"
                   FontSize="24"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="14,0,0,0"/>

        <Grid Grid.Row="1" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Height="36"
                      Background="#D9D9D9"
                      Foreground="Black"
                      FontSize="13"
                      FontWeight="Bold"
                      BorderThickness="0"
                      Padding="12,0"
                      SelectedItem="{Binding SelectedPledgeFilter}">
                <ComboBoxItem Content="All Pledges"/>
                <ComboBoxItem Content="Pending"/>
                <ComboBoxItem Content="Approved"/>
                <ComboBoxItem Content="Fulfilled"/>
                <ComboBoxItem Content="Cancelled"/>
            </ComboBox>

            <Border Grid.Column="2"
                    Height="36"
                    Background="#D9D9D9"
                    CornerRadius="3">

                <Grid>
                    <TextBox Text="{Binding PledgeSearchText}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="13"
                             FontWeight="Bold"
                             Foreground="Black"
                             Padding="12,0,34,0"
                             VerticalContentAlignment="Center"/>

                    <TextBlock Text="🔍"
                               FontSize="15"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                </Grid>

            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#D9D9D9"
                Margin="10,0,10,0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Pledge ID" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Event" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Items" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Expected Date" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Status" FontSize="13" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

        </Border>

        <Border Grid.Row="3"
                Background="#2C2C2C"
                Margin="10,0,10,10"
                ClipToBounds="True">

            <DataGrid ItemsSource="{Binding MyPledges}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="None"
                      CanUserAddRows="False"
                      CanUserResizeRows="False"
                      CanUserResizeColumns="False"
                      GridLinesVisibility="None"
                      Background="#2C2C2C"
                      RowBackground="#2C2C2C"
                      AlternatingRowBackground="#343434"
                      Foreground="White"
                      BorderThickness="0"
                      RowHeight="34"
                      FontSize="13"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding PledgeId}" Width="1.1*"/>
                    <DataGridTextColumn Binding="{Binding Event}" Width="1*"/>
                    <DataGridTextColumn Binding="{Binding Item}" Width="1.2*"/>
                    <DataGridTextColumn Binding="{Binding ExpectedDate}" Width="1.2*"/>
                    <DataGridTextColumn Binding="{Binding Status}" Width="1*"/>
                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>
</UserControl>