<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_donation_Waste_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             VerticalAlignment="Stretch"
             MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ContentControl}}"
             MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ContentControl}}"
             Background="Transparent">

    <Grid Background="#2C2C2C"
          HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
          Margin="0,0,0,10">

        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Waste"
                   Style="{StaticResource TableH1}"
                   FontSize="18"/>

        <Grid Grid.Row="1"
              Margin="8,0,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource Combo1}"
                      VerticalAlignment="Bottom"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding SelectedWasteFilter}">
                <ComboBoxItem Content="Filter"/>
                <ComboBoxItem Content="All Records"/>
                <ComboBoxItem Content="Expired"/>
                <ComboBoxItem Content="Damaged"/>
                <ComboBoxItem Content="Disposed"/>
            </ComboBox>

            <Border Grid.Column="2"
                    Height="26"
                    Background="White"
                    VerticalAlignment="Bottom">
                <Grid>
                    <TextBox Text="{Binding WasteSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Searchbox}"/>

                    <TextBlock Text="Search"
                               Style="{StaticResource Search}"/>

                    <Viewbox Width="14"
                             Height="14"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0">
                        <Canvas Width="18" Height="18">
                            <Ellipse Style="{StaticResource Ellipse1}"/>
                            <Path Data="M10,10 L16,16" Style="{StaticResource Path1}"/>
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#D9D9D9"
                Margin="8,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Waste ID" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="1" Text="Inventory Item" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="2" Text="Quantity" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="3" Text="Reason" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="4" Text="Date" Style="{StaticResource TableSub1}"/>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                Margin="8,0,8,0"
                ClipToBounds="True">

            <DataGrid ItemsSource="{Binding WasteRecords}"
                      SelectedItem="{Binding SelectedWaste}"
                      AutoGenerateColumns="False"
                      Style="{StaticResource Table}">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding WasteId}"       Width="1*"   IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding InventoryItem}" Width="1.3*" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding Quantity}"      Width="1*"   IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding Reason}"        Width="1.3*" IsReadOnly="True"/>

                    <!-- Date: DatePicker in cell -->
                    <DataGridTemplateColumn Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Date, StringFormat=yyyy-MM-dd}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding Date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            BorderThickness="0" Background="Transparent"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

        </Border>
    </Grid>
</UserControl>