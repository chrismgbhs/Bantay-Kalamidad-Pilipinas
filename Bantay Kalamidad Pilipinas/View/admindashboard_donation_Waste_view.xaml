<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_donation_Waste_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Waste"
                   FontSize="20"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="14,0,0,0"/>

        <Grid Grid.Row="1" Margin="14,0,14,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Height="28"
                      Background="#D9D9D9"
                      Foreground="Black"
                      FontSize="11"
                      FontWeight="Bold"
                      BorderThickness="0"
                      Padding="8,0"
                      SelectedItem="{Binding SelectedWasteFilter}">
                <ComboBoxItem Content="All Records"/>
                <ComboBoxItem Content="Expired"/>
                <ComboBoxItem Content="Damaged"/>
                <ComboBoxItem Content="Disposed"/>
            </ComboBox>

            <Border Grid.Column="2"
                    Height="28"
                    Background="#D9D9D9"
                    CornerRadius="3">
                <Grid>
                    <TextBox Text="{Binding WasteSearchText}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="11"
                             FontWeight="Bold"
                             Foreground="Black"
                             Padding="10,0,32,0"
                             VerticalContentAlignment="Center"/>

                    <TextBlock Text="🔍"
                               FontSize="13"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#D9D9D9"
                Margin="14,0,14,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Waste ID" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Inventory Item" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Quantity" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Reason" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Date" FontSize="11" FontWeight="Black" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="#2C2C2C"
                Margin="14,0,14,0"
                ClipToBounds="True">

            <DataGrid ItemsSource="{Binding WasteRecords}"
                      SelectedItem="{Binding SelectedWaste}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="None"
                      CanUserAddRows="False"
                      CanUserResizeRows="False"
                      CanUserResizeColumns="False"
                      GridLinesVisibility="None"
                      Background="#2C2C2C"
                      RowBackground="#2C2C2C"
                      AlternatingRowBackground="#343434"
                      Foreground="White"
                      BorderThickness="0"
                      RowHeight="26"
                      FontSize="11"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding WasteId}" Width="1*"/>
                    <DataGridTextColumn Binding="{Binding InventoryItem}" Width="1.3*"/>
                    <DataGridTextColumn Binding="{Binding Quantity}" Width="1*"/>
                    <DataGridTextColumn Binding="{Binding Reason}" Width="1.3*"/>
                    <DataGridTextColumn Binding="{Binding Date}" Width="1.2*"/>
                </DataGrid.Columns>
            </DataGrid>

        </Border>

        <Grid Grid.Row="4"
              Background="#7F7F7F"
              Visibility="{Binding ActionButtonsVisibility}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0">

                <Button Content="SAVE"
                        Width="75"
                        Height="26"
                        Background="Transparent"
                        Foreground="Black"
                        FontSize="11"
                        FontWeight="Black"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding SaveCommand}"/>

                <Button Content="UPDATE"
                        Width="85"
                        Height="26"
                        Background="Transparent"
                        Foreground="Black"
                        FontSize="11"
                        FontWeight="Black"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding UpdateCommand}"/>

                <Button Content="DELETE"
                        Width="75"
                        Height="26"
                        Background="Transparent"
                        Foreground="Black"
                        FontSize="11"
                        FontWeight="Black"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding DeleteCommand}"/>

            </StackPanel>
        </Grid>

    </Grid>
</UserControl>