<Window x:Class="Bantay_Kalamidad_Pilipinas.View.DonationLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bantay_Kalamidad_Pilipinas.View"
        mc:Ignorable="d"
        Title="DonationLogin" Height="450" Width="800">
    <Grid Background="white">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">

            <Border x:Name="HeaderBorder" CornerRadius="6" Padding="16,10"
                    Margin="0,0,0,24" HorizontalAlignment="Stretch">
                <StackPanel>
                    <TextBlock x:Name="PortalIcon" Text="" FontSize="24"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock x:Name="PortalTitle" Text="DONATION LOGIN"
                               FontSize="16" FontWeight="Bold" Foreground="Black"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="PortalSubtitle" Text=""
                               FontSize="11" Foreground="#CCCCCC"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Username -->
            <TextBlock Text="Username" Foreground="Black" FontSize="12"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="TxtUsername" Height="38" FontSize="13"
                     Background="White" Foreground="Black"
                     BorderBrush="#444466" BorderThickness="1"
                     Padding="10,0" VerticalContentAlignment="Center"
                     Margin="0,0,0,16"
                     CaretBrush="White"
                     Text="{Binding CurrentUser.Username, UpdateSourceTrigger=PropertyChanged}"
                     />

            <!-- Password -->
            <TextBlock Text="Password" Foreground="Black" FontSize="12"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="TxtPassword" Height="38" FontSize="13"
                         Background="White" Foreground="Black"
                         BorderBrush="#444466" BorderThickness="1"
                         Padding="10,0" VerticalContentAlignment="Center"
                         Margin="0,0,0,8"
                         Text="{Binding CurrentUser.Password, UpdateSourceTrigger=PropertyChanged}"
                         />

            <!-- Error Message -->
            <TextBlock x:Name="TxtError" Text="" Foreground="#E74C3C"
                       FontSize="11" HorizontalAlignment="Center"
                       Margin="0,0,0,16" Visibility="Collapsed"/>

            <!-- Login Button -->
            <Button x:Name="BtnLogin" Content="LOG IN"
                    Height="42" FontSize="13" FontWeight="Bold"
                    Foreground="White" BorderThickness="0"
                    Cursor="Hand" Margin="0,0,0,16"
                    Command="{Binding LoginCommand}"
                    >
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Blue"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#C0392B"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#922B21"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Back Button -->
            <Button Content="← Back to Portal Selection"
                    Background="Transparent" Foreground="Black"
                    BorderThickness="0" FontSize="11"
                    Cursor="Hand" HorizontalAlignment="Center" 
                    Command="{Binding ViewPortalCommand}"
                    >
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#888888"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="{TemplateBinding FontSize}"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
