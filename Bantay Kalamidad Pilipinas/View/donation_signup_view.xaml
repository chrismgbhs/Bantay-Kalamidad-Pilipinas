<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.donation_signup_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Viewbox Stretch="Uniform">
        <Grid Width="1100" Height="750">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,75,0,25">

                <Image Source="/Images/bkp_logo.png"
                       Width="75"
                       Height="75"
                       Margin="0,0,18,0"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Bantay Kalamidad Pilipinas"
                               FontSize="28"
                               FontWeight="Black"/>
                    <TextBlock Text="Disaster Response and Relief Coordination System"
                               FontSize="20"
                               FontWeight="Bold"/>
                </StackPanel>

            </StackPanel>

            <Grid Grid.Row="1">

                <Border Width="430"
                        Height="520"
                        BorderBrush="#07314E"
                        BorderThickness="3"
                        CornerRadius="10"
                        Background="White"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,5,0,0">

                    <StackPanel Margin="48,25,48,0">

                        <TextBlock Text="DONOR SIGN UP"
                                   FontSize="16"
                                   FontWeight="Black"
                                   HorizontalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,5,0,22">

                            <TextBlock Text="Already have an account? "
                                       FontSize="12"
                                       Foreground="#777"/>

                            <Button Content="Sign in"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="Black"
                                    FontSize="12"
                                    Cursor="Hand"
                                    Command="{Binding OpenSigninCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   TextDecorations="Underline"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="First name" FontSize="13"/>
                                <TextBox Height="35"
                                         Margin="0,5,0,0"
                                         Padding="10"
                                         Text="{Binding FirstName}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Last name" FontSize="13"/>
                                <TextBox Height="35"
                                         Margin="0,5,0,0"
                                         Padding="10"
                                         Text="{Binding LastName}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Email address" FontSize="13"/>
                        <TextBox Height="35"
                                 Margin="0,5,0,18"
                                 Padding="10"
                                 Text="{Binding EmailAddress}"/>

                        <TextBlock Text="Phone number" FontSize="13"/>
                        <TextBox Height="35"
                                 Margin="0,5,0,18"
                                 Padding="10"
                                 Text="{Binding PhoneNumber}"/>

                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="Password"
                                       FontSize="13"
                                       HorizontalAlignment="Left"/>

                            <Button Content="Hide"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#777"
                                    FontSize="11"
                                    HorizontalAlignment="Right"
                                    Cursor="Hand"
                                    Command="{Binding TogglePasswordVisibilityCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   FontSize="{TemplateBinding FontSize}"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <PasswordBox Height="35"
                                     Margin="0,0,0,25"
                                     Padding="10"/>

                        <Button Content="Sign up"
                                Height="40"
                                Margin="0,0,0,25"
                                Background="#07314E"
                                Foreground="White"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Command="{Binding SignupCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,20">

                            <Button Width="55" Height="38" Margin="5"
                                    Background="White"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    Command="{Binding FacebookLoginCommand}">
                                <Image Source="/Images/fb_logo.png" Width="18"/>
                            </Button>

                            <Button Width="55" Height="38" Margin="5"
                                    Background="White"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    Command="{Binding InstagramLoginCommand}">
                                <Image Source="/Images/ig_logo.png" Width="18"/>
                            </Button>

                            <Button Width="55" Height="38" Margin="5"
                                    Background="White"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    Command="{Binding GoogleLoginCommand}">
                                <Image Source="/Images/google_logo.png" Width="18"/>
                            </Button>

                            <Button Width="55" Height="38" Margin="5"
                                    Background="White"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    Command="{Binding XLoginCommand}">
                                <Image Source="/Images/x_logo.png" Width="18"/>
                            </Button>

                        </StackPanel>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>
    </Viewbox>
</UserControl>