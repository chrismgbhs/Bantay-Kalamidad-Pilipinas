<Window x:Class="Bantay_Kalamidad_Pilipinas.View.donationdashboard_mainlayout_view"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Donation Dashboard"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="CanResize">

    <Viewbox Stretch="Uniform">
        <Grid Width="1000"
              Height="700"
              Background="#EDEDED">

            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="62"/>
                    <RowDefinition Height="54"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Background="White">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="275"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="10,0,0,0">
                        <Image Source="/Images/bkp_logo.png"
                               Width="44"
                               Height="44"
                               Margin="0,0,9,0"/>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource OrgName1}"/>
                            <TextBlock Style="{StaticResource SystemName1}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                        <TextBlock Text="Welcome, Donor!"
                                   FontSize="18"
                                   Style="{StaticResource LoginHeader}"
                                   Margin="0,0,16,0"/>

                        <Viewbox Width="32" Height="32" VerticalAlignment="Center">
                            <Canvas Width="32" Height="32">
                                <Ellipse Style="{StaticResource Ellipse2}"/>
                                <Path Data="M5,28 C5,20 10,16 16,16 C22,16 27,20 27,28"
                                      Style="{StaticResource Path2}"/>
                            </Canvas>
                        </Viewbox>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Background="#07314E">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="58"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Background="{StaticResource DonorBorder}"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Viewbox Width="31" Height="31">
                                <Path Data="M25,5 L8,16 L25,27 M8,16 L31,16"
                                      Style="{StaticResource Path3}"/>
                            </Viewbox>
                        </Button>

                        <Button Grid.Column="1"
                                Style="{StaticResource Menubtn}"
                                Background="{StaticResource DonorBorder}"
                                Command="{Binding ShowMyDonationsCommand}">
                            <TextBlock Text="My Donations"
                                       TextDecorations="Underline"
                                       FontWeight="Black"/>
                        </Button>

                        <Grid Grid.Column="2">
                            <Button Style="{StaticResource Menubtn}"
                                    Background="{StaticResource DonorBorder}"
                                    Command="{Binding TogglePledgeMenuCommand}">
                                <TextBlock Text="Pledge"
                                           FontWeight="Black"/>
                            </Button>

                            <Popup IsOpen="{Binding IsPledgeMenuOpen}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                                   AllowsTransparency="True"
                                   StaysOpen="False">
                                <Border Width="150"
                                        Background="#D9D9D9"
                                        BorderBrush="#BFBFBF"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <Button Content="Make a Pledge"
                                                Height="30"
                                                Background="#D9D9D9"
                                                Foreground="Black"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding ShowMakePledgeCommand}"/>
                                        <Button Content="My Pledges"
                                                Height="30"
                                                Background="#D9D9D9"
                                                Foreground="Black"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding ShowMyPledgesCommand}"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <Button Grid.Column="3"
                                Style="{StaticResource Menubtn}"
                                Background="{StaticResource DonorBorder}"
                                Command="{Binding ShowPickupDeliveryCommand}">
                            <TextBlock Text="Pickup &amp; Delivery"
                                       FontWeight="Black"/>
                        </Button>

                        <Button Grid.Column="4"
                                Style="{StaticResource Menubtn}"
                                Background="{StaticResource DonorBorder}"
                                Command="{Binding ShowAboutUsCommand}">
                            <TextBlock Text="About Us"
                                       FontWeight="Black"/>
                        </Button>

                        <Button Grid.Column="5"
                                Style="{StaticResource Menubtn}"
                                Background="{StaticResource DonorBorder}"
                                Command="{Binding ShowContactUsCommand}">
                            <TextBlock Text="Contact Us"
                                       FontWeight="Black"/>
                        </Button>

                        <Button Grid.Column="6"
                                Background="{StaticResource DonorBorder}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding LogoutCommand}">
                            <Viewbox Width="31" Height="31">
                                <Canvas Width="32" Height="32">
                                    <Path Data="M7,7 L19,7 L19,12"
                                          Style="{StaticResource Path3}"/>
                                    <Path Data="M19,22 L19,27 L7,27 L7,7"
                                          Style="{StaticResource Path3}"/>
                                    <Path Data="M17,17 L29,17"
                                          Style="{StaticResource Path4}"/>
                                    <Path Data="M24,11 L30,17 L24,23"
                                          Style="{StaticResource Path3}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="2"
                      Margin="12,12,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="248"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#07314E"
                                Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="My Total Donations"
                                           Style="{StaticResource InfoCardTitle}"/>

                                <TextBlock Style="{StaticResource InfoLabel}">
                                    <Run Text="Total Item Count: "/>
                                    <Run Text="{Binding TotalItemCount}"/>
                                </TextBlock>

                                <TextBlock Style="{StaticResource InfoLabel}">
                                    <Run Text="Last Donation Date: "/>
                                    <Run Text="{Binding LastDonationDate}"/>
                                </TextBlock>

                                <TextBlock Style="{StaticResource InfoLabel}">
                                    <Run Text="Impact Summary: "/>
                                    <Run Text="{Binding ImpactSummary}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Background="#07314E"
                                Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="Active Pledges"
                                           Style="{StaticResource InfoCardTitle}"/>

                                <TextBlock Style="{StaticResource InfoLabel}">
                                    <Run Text="Open Pledges Count: "/>
                                    <Run Text="{Binding ActivePledgesCount}"/>
                                </TextBlock>

                                <TextBlock Style="{StaticResource InfoLabel}">
                                    <Run Text="Next Pending Item: "/>
                                    <Run Text="{Binding NextPendingItem}"/>
                                </TextBlock>

                                <TextBlock Style="{StaticResource InfoLabel}">
                                    <Run Text="Completion Rate: "/>
                                    <Run Text="{Binding PledgeCompletionRate}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4"
                                Background="#07314E"
                                Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="Scheduled Pickups"
                                           Style="{StaticResource InfoCardTitle}"/>

                                <TextBlock Style="{StaticResource InfoLabel}">
                                    <Run Text="Next Pickup Date &amp; Time: "/>
                                    <Run Text="{Binding NextPickupDateTime}"/>
                                </TextBlock>

                                <TextBlock Style="{StaticResource InfoLabel}">
                                    <Run Text="Pickup Location: "/>
                                    <Run Text="{Binding PickupLocation}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="6"
                                Background="#07314E"
                                Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="Scheduled Deliveries"
                                           Style="{StaticResource InfoCardTitle}"/>

                                <TextBlock Style="{StaticResource InfoLabel}">
                                    <Run Text="Next Drop-off Date &amp; Time: "/>
                                    <Run Text="{Binding NextDropOffDateTime}"/>
                                </TextBlock>

                                <TextBlock Style="{StaticResource InfoLabel}">
                                    <Run Text="Destination Hub: "/>
                                    <Run Text="{Binding DestinationHub}"/>
                                </TextBlock>

                                <TextBlock Style="{StaticResource InfoLabel}">
                                    <Run Text="Status: "/>
                                    <Run Text="{Binding DeliveryStatus}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Column="2"
                            Background="White"
                            BorderBrush="#333333"
                            BorderThickness="6"
                            Padding="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ContentControl Content="{Binding CurrentDonationDashboardView}"
                                            HorizontalContentAlignment="Stretch"
                                            VerticalContentAlignment="Stretch"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Viewbox>
</Window>