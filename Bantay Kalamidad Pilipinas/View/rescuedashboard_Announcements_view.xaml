<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.rescuedashboard_Announcements_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Announcements"
                   FontSize="18"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"/>

        <TextBlock Grid.Row="1"
                   Text="URGENT"
                   FontSize="13"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"/>

        <Border Grid.Row="2"
                Background="White"
                Margin="8,0,8,0"
                ClipToBounds="True">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="10">
                <TextBlock Text="{Binding UrgentAnnouncement}"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Foreground="Black"/>
            </ScrollViewer>

        </Border>

        <TextBlock Grid.Row="4"
                   Text="UPDATE"
                   FontSize="13"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"/>

        <Border Grid.Row="5"
                Background="White"
                Margin="8,0,8,8"
                ClipToBounds="True">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="10">
                <TextBlock Text="{Binding UpdateAnnouncement}"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Foreground="Black"/>
            </ScrollViewer>

        </Border>

    </Grid>
</UserControl>