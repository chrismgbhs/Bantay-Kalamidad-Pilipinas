<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.rescuedashboard_Announcements_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Announcements"
                   FontSize="24"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="14,0,0,0"/>

        <TextBlock Grid.Row="1"
                   Text="URGENT"
                   FontSize="18"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="14,0,0,0"/>

        <Border Grid.Row="2"
                Background="#D9D9D9"
                CornerRadius="0"
                Margin="14,0,14,0">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="12">
                <TextBlock Text="{Binding UrgentAnnouncement}"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Foreground="Black"/>
            </ScrollViewer>

        </Border>

        <TextBlock Grid.Row="3"
                   Text="UPDATE"
                   FontSize="18"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="14,0,0,0"/>

        <Border Grid.Row="4"
                Background="#D9D9D9"
                CornerRadius="0"
                Margin="14,0,14,10">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="12">
                <TextBlock Text="{Binding UpdateAnnouncement}"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Foreground="Black"/>
            </ScrollViewer>

        </Border>

    </Grid>
</UserControl>