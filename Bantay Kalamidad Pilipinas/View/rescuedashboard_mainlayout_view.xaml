<Window x:Class="Bantay_Kalamidad_Pilipinas.View.rescuedashboard_mainlayout_view"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rescue Dashboard"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="CanResize">

    <Viewbox Stretch="Uniform">
        <Grid Width="1100" Height="750" Background="White">

            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="62"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="70,28,70,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Images/bkp_logo.png"
                           Width="70"
                           Height="70"
                           Margin="0,0,16,0"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Bantay Kalamidad Pilipinas"
                                   FontSize="24"
                                   FontWeight="Black"/>
                        <TextBlock Text="Disaster Response and Relief Coordination System"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Column="1"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="Welcome, Rescuer!"
                                   FontSize="17"
                                   FontWeight="Black"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,0,8"/>

                        <Button Content="Logout"
                                Width="150"
                                Height="32"
                                Background="#7F7F7F"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding LogoutCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="👤"
                               FontSize="34"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Grid>

            <Border Grid.Row="1"
                    Height="50"
                    Background="#A30000"
                    Margin="85,0,85,0"
                    VerticalAlignment="Center">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="My Rescue Operations"
                            Background="#A30000" Foreground="White"
                            FontSize="14" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand"
                            Command="{Binding ShowMyRescueOperationsCommand}"/>

                    <Button Grid.Column="1" Content="My Team"
                            Background="#A30000" Foreground="White"
                            FontSize="14" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand"
                            Command="{Binding ShowMyTeamCommand}"/>

                    <Button Grid.Column="2" Content="Rescue Locations"
                            Background="#A30000" Foreground="White"
                            FontSize="14" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand"
                            Command="{Binding ShowRescueLocationsCommand}"/>

                    <Button Grid.Column="3" Content="Announcements"
                            Background="#A30000" Foreground="White"
                            FontSize="14" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand"
                            Command="{Binding ShowAnnouncementsCommand}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="85,12,85,45">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#A30000"
                            CornerRadius="10"
                            Margin="0,0,0,12"
                            Padding="16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Active Disaster Event"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       TextAlignment="Center"/>
                            <TextBlock Text="{Binding ActiveDisasterEvent, FallbackValue=No active event selected}"
                                       Foreground="White"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#A30000"
                            CornerRadius="10"
                            Margin="0,0,0,12"
                            Padding="16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="My Assigned Operations"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       TextAlignment="Center"/>
                            <TextBlock Text="{Binding AssignedOperationsCount, FallbackValue=0}"
                                       Foreground="White"
                                       FontSize="28"
                                       FontWeight="Black"
                                       TextAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Background="#A30000"
                            CornerRadius="10"
                            Padding="16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Current Rescue Operations"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CurrentOperationsCount, FallbackValue=0}"
                                       Foreground="White"
                                       FontSize="28"
                                       FontWeight="Black"
                                       TextAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Column="2"
                        Background="#F6F6F6"
                        CornerRadius="10"
                        BorderBrush="#D9D9D9"
                        BorderThickness="1"
                        Padding="16">

                    <ContentControl Content="{Binding CurrentRescueDashboardView}">
                        <ContentControl.Template>
                            <ControlTemplate TargetType="ContentControl">
                                <Border Background="White"
                                        CornerRadius="10"
                                        BorderBrush="#DDDDDD"
                                        BorderThickness="1">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </ContentControl.Template>
                    </ContentControl>

                </Border>

            </Grid>

        </Grid>
    </Viewbox>
</Window>