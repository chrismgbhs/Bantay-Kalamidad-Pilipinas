<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.donationdashboard_AboutUs_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <TextBlock Text="About Us"
                   FontSize="24"
                   FontWeight="Black"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="14,0,0,0"/>

        <TextBlock Grid.Row="1"
                   Text="About Bantay Kalamidad Pilipinas"
                   FontSize="15"
                   FontWeight="Black"
                   Foreground="White"
                   Margin="14,0,0,0"
                   VerticalAlignment="Center"/>

        <TextBox Grid.Row="2"
                 Text="{Binding AboutText}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="#D9D9D9"
                 Foreground="Black"
                 BorderThickness="0"
                 FontSize="13"
                 Margin="14,0,14,10"
                 Padding="10"/>

        <TextBlock Grid.Row="3"
                   Text="Mission"
                   FontSize="15"
                   FontWeight="Black"
                   Foreground="White"
                   Margin="14,0,0,0"
                   VerticalAlignment="Center"/>

        <TextBox Grid.Row="4"
                 Text="{Binding MissionText}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="#D9D9D9"
                 Foreground="Black"
                 BorderThickness="0"
                 FontSize="13"
                 Margin="14,0,14,10"
                 Padding="10"/>

        <TextBlock Grid.Row="5"
                   Text="Vision"
                   FontSize="15"
                   FontWeight="Black"
                   Foreground="White"
                   Margin="14,0,0,0"
                   VerticalAlignment="Center"/>

        <TextBox Grid.Row="6"
                 Text="{Binding VisionText}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="#D9D9D9"
                 Foreground="Black"
                 BorderThickness="0"
                 FontSize="13"
                 Margin="14,0,14,10"
                 Padding="10"/>

        <TextBlock Grid.Row="7"
                   Text="How the System Works"
                   FontSize="15"
                   FontWeight="Black"
                   Foreground="White"
                   Margin="14,0,0,0"
                   VerticalAlignment="Center"/>

        <TextBox Grid.Row="8"
                 Text="{Binding HowItWorksText}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="#D9D9D9"
                 Foreground="Black"
                 BorderThickness="0"
                 FontSize="13"
                 Margin="14,0,14,10"
                 Padding="10"/>

    </Grid>
</UserControl>