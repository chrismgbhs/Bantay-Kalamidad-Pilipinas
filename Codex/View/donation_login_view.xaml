<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.donation_login_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Viewbox Stretch="Uniform">
        <Grid Width="1200" Height="800" Background="White">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <!-- Header Section -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,40">

                    <Image Source="/Images/bkp_logo.png"
                           Width="85"
                           Height="85"
                           Margin="0,0,20,0"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource OrgName}"/>
                        <TextBlock Style="{StaticResource SystemName}"/>
                    </StackPanel>

                </StackPanel>

                <!-- Login Card -->
                <Border Style="{StaticResource LoginBorder}"
                        BorderBrush="{StaticResource DonorBorder}">

                    <Grid>

                        <Button Style="{StaticResource Arrow}"
                                Margin="18,14,0,0"
                                Command="{Binding BackCommand}">
                            <TextBlock Text="&#xE72B;"
                                       Style="{StaticResource ArrowText}"/>
                        </Button>

                        <StackPanel Margin="55,45,55,0">

                            <TextBlock Text="DONOR SIGN IN"
                                       Style="{StaticResource LoginHeader}"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,6,0,40">

                                <TextBlock Text="New to BKP? "
                                           Style="{StaticResource LoginSub2}"/>

                                <Button Content="Sign up"
                                        Style="{StaticResource Transitionbtn}"
                                        Command="{Binding OpenSignupCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}"
                                                       TextDecorations="Underline"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                            </StackPanel>

                            <!-- Email Input -->
                            <TextBlock Text="Email Address"
                                       Style="{StaticResource LoginSub}"
                                       Margin="0,0,0,6"/>

                            <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                                     Margin="0,0,0,16"
                                     Text="{Binding CurrentUser.Username}"/>


                            <!-- Password Input -->
                            <TextBlock Text="Password"
                                       Style="{StaticResource LoginSub}"
                                       Margin="0,0,0,6"/>

                            <PasswordBox x:Name="passwordBox"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         Style="{StaticResource Passbox}"
                                         Margin="0,0,0,8"/>

                            <!-- Forgot Password Link -->
                            <Button Content="Forgot password?"
                                    Style="{StaticResource ForgetPassbtn}"
                                    Margin="0,0,0,30"
                                    Command="{Binding ForgotPasswordCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   TextDecorations="Underline"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Sign In Button -->
                            <Button Content="Sign in"
                                    Style="{StaticResource Signinbtn}"
                                    Background="{StaticResource DonorBorder}"
                                    Foreground="White"
                                    Margin="0,0,0,20"
                                    Command="{Binding LoginCommand}"/>


                            <!-- Google Sign In Button -->
                            <Button Style="{StaticResource Googlebtn}"
                                    Command="{Binding GoogleLoginCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="#D6D6D6"
                                                BorderThickness="1"
                                                CornerRadius="21">
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Image Source="/Images/website icons (2).png"
                                                       Width="20"
                                                       Margin="0,0,10,0"/>
                                                <TextBlock Text="Sign in with Google" 
                                                           Style="{StaticResource Google}"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>

                    </Grid>

                </Border>

            </StackPanel>

        </Grid>
    </Viewbox>
</UserControl>