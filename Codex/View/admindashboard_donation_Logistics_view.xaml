<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_donation_Logistics_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C"
          Margin="0,0,0,10">

        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="82"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Deliveries"
                   Style="{StaticResource TableH1}"/>

        <Grid Grid.Row="1"
              Margin="8,0,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource Combo1}"
                      VerticalAlignment="Bottom"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding SelectedDeliveryFilter}">
                <ComboBoxItem Content="Filter"/>
                <ComboBoxItem Content="All Deliveries"/>
                <ComboBoxItem Content="Pending"/>
                <ComboBoxItem Content="In Transit"/>
                <ComboBoxItem Content="Delivered"/>
            </ComboBox>

            <Border Grid.Column="2"
                    Height="26"
                    Background="White"
                    VerticalAlignment="Bottom">
                <Grid>
                    <TextBox Text="{Binding DeliverySearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Searchbox}"/>

                    <TextBlock Text="Search"
                               Style="{StaticResource Search}"/>

                    <Viewbox Width="14"
                             Height="14"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0">
                        <Canvas Width="18" Height="18">
                            <Ellipse Style="{StaticResource Ellipse1}"/>
                            <Path Data="M10,10 L16,16" Style="{StaticResource Path1}"/>
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#D9D9D9"
                Margin="8,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Delivery ID" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="1" Text="Distribution" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="2" Text="Delivery Date" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="3" Text="Status" Style="{StaticResource TableSub1}"/>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                Margin="8,0,8,0"
                ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Deliveries}"
                      SelectedItem="{Binding SelectedDelivery}"
                      AutoGenerateColumns="False"
                      Style="{StaticResource Table}">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding DeliveryId}" Width="1*" IsReadOnly="True"/>

                    <!-- Distribution: ComboBox in cell -->
                    <DataGridTemplateColumn Width="1.3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Distribution}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableDistributions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          SelectedItem="{Binding DataContext.SelectedDistributionDropdown, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay}"
                                          DisplayMemberPath="Display" BorderThickness="0" Background="White"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Delivery Date: DatePicker in cell -->
                    <DataGridTemplateColumn Width="1.3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DeliveryDate, StringFormat=yyyy-MM-dd}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding DeliveryDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            BorderThickness="0" Background="Transparent"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status: ComboBox -->
                    <DataGridTemplateColumn Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedValue="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          BorderThickness="0" Background="White">
                                    <ComboBoxItem Content="Pending"/>
                                    <ComboBoxItem Content="In Transit"/>
                                    <ComboBoxItem Content="Delivered"/>
                                    <ComboBoxItem Content="Cancelled"/>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="4"
                   Text="Pickups"
                   Style="{StaticResource TableH1}"/>

        <Grid Grid.Row="5"
              Margin="8,0,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource Combo1}"
                      VerticalAlignment="Bottom"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding SelectedPickupFilter}">
                <ComboBoxItem Content="Filter"/>
                <ComboBoxItem Content="All Pickups"/>
                <ComboBoxItem Content="Scheduled"/>
                <ComboBoxItem Content="Completed"/>
                <ComboBoxItem Content="Cancelled"/>
            </ComboBox>

            <Border Grid.Column="2"
                    Height="26"
                    Background="White"
                    VerticalAlignment="Bottom">
                <Grid>
                    <TextBox Text="{Binding PickupSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Searchbox}"/>

                    <TextBlock Text="Search"
                               Style="{StaticResource Search}"/>

                    <Viewbox Width="14"
                             Height="14"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0">
                        <Canvas Width="18" Height="18">
                            <Ellipse Style="{StaticResource Ellipse1}"/>
                            <Path Data="M10,10 L16,16" Style="{StaticResource Path1}"/>
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="6"
                Background="#D9D9D9"
                Margin="8,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Pickup ID" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="1" Text="Donation" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="2" Text="Pickup Date" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="3" Text="Status" Style="{StaticResource TableSub1}"/>
            </Grid>
        </Border>

        <Border Grid.Row="7"
                Background="White"
                Margin="8,0,8,0"
                ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Pickups}"
                      SelectedItem="{Binding SelectedPickup}"
                      AutoGenerateColumns="False"
                      Style="{StaticResource Table}">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding PickupId}" Width="1*" IsReadOnly="True"/>

                    <!-- Donation: ComboBox in cell -->
                    <DataGridTemplateColumn Width="1.3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Donation}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableDonations, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          SelectedItem="{Binding DataContext.SelectedDonationDropdown, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay}"
                                          DisplayMemberPath="Display" BorderThickness="0" Background="White"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Pickup Date: DatePicker -->
                    <DataGridTemplateColumn Width="1.3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PickupDate, StringFormat=yyyy-MM-dd}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding PickupDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            BorderThickness="0" Background="Transparent"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status: ComboBox -->
                    <DataGridTemplateColumn Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedValue="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          BorderThickness="0" Background="White">
                                    <ComboBoxItem Content="Scheduled"/>
                                    <ComboBoxItem Content="Completed"/>
                                    <ComboBoxItem Content="Cancelled"/>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="8"
              Background="#7F7F7F"
              Margin="8,0,8,0"
              Visibility="{Binding ActionButtonsVisibility}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">

                <Button Content="SAVE"
                        Style="{StaticResource CRUDbtn}" 
                        Command="{Binding SaveCommand}"/>

                <Button Content="UPDATE" 
                        Style="{StaticResource CRUDbtn}"
                        Command="{Binding UpdateCommand}"/>

                <Button Content="DELETE"
                        Style="{StaticResource CRUDbtn}" 
                        Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>