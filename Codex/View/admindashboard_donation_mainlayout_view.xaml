<Window x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_donation_mainlayout_view"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard - Donations"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="CanResize">

    <Viewbox Stretch="Uniform">
        <Grid Width="1100" Height="750" Background="White">

            <Grid.RowDefinitions>
                <RowDefinition Height="74"/>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#F7F8FA"
                  Margin="14,10,14,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="270"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">

                    <Image Source="/Images/bkp_logo.png"
                           Width="44"
                           Height="44"
                           Margin="0,0,10,0"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource OrgName1}"/>
                        <TextBlock Style="{StaticResource SystemName1}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">

                    <TextBlock Text="Welcome, Admin!"
                               Style="{StaticResource LoginHeader}"
                               FontSize="18"
                               Margin="0,0,10,0"/>

                    <Viewbox Width="32"
                             Height="32"
                             VerticalAlignment="Center">
                        <Canvas Width="32" Height="32">
                            <Ellipse Style="{StaticResource Ellipse2}"/>
                            <Path Data="M5,28 C5,20 10,16 16,16 C22,16 27,20 27,28"
                                  Style="{StaticResource Path2}"/>
                        </Canvas>
                    </Viewbox>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1"
                  Background="{StaticResource DonorBorder}"
                  Margin="14,0,14,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="72"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Viewbox Width="34" Height="34">
                        <Canvas Width="34" Height="34">
                            <Path Data="M21,8 L12,17 L21,26"
                                  Style="{StaticResource Path3}"/>
                            <Path Data="M13,17 L29,17"
                                  Style="{StaticResource Path4}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Grid.Column="1"
                        Content="Donations"
                        Background="{StaticResource DonorBorder}"
                        Style="{StaticResource Menubtn}"
                        Command="{Binding ShowDonationsCommand}"/>

                <Button Grid.Column="2"
                        Content="Pledges"
                        Background="{StaticResource DonorBorder}"
                        Style="{StaticResource Menubtn}"
                        Command="{Binding ShowPledgesCommand}"/>

                <Button Grid.Column="3"
                        Content="Logistics"
                        Background="{StaticResource DonorBorder}"
                        Style="{StaticResource Menubtn}"
                        Command="{Binding ShowLogisticsCommand}"/>

                <Button Grid.Column="4"
                        Content="Inventory"
                        Background="{StaticResource DonorBorder}"
                        Style="{StaticResource Menubtn}"
                        Command="{Binding ShowInventoryCommand}"/>

                <Button Grid.Column="5"
                        Content="Distribution"
                        Background="{StaticResource DonorBorder}"
                        Style="{StaticResource Menubtn}"
                        Command="{Binding ShowDistributionCommand}"/>

                <Button Grid.Column="6"
                        Content="Waste"
                        Background="{StaticResource DonorBorder}"
                        Style="{StaticResource Menubtn}"
                        Command="{Binding ShowWasteCommand}"/>

                <Button Grid.Column="7"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding LogoutCommand}">
                    <Viewbox Width="34" Height="34">
                        <Canvas Width="34" Height="34">
                            <Path Data="M7,7 L19,7 L19,12"
                                  Style="{StaticResource Path3}"/>
                            <Path Data="M19,22 L19,27 L7,27 L7,7"
                                  Style="{StaticResource Path3}"/>
                            <Path Data="M17,17 L29,17"
                                  Style="{StaticResource Path4}"/>
                            <Path Data="M24,11 L30,17 L24,23"
                                  Style="{StaticResource Path3}"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>

            <Grid Grid.Row="2"
                  Background="#D9D9D9"
                  Margin="14,8,14,14">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="158"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#07314E"
                        Padding="14"
                        Margin="0">

                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,14">
                            <TextBlock Text="{Binding SelectedDonationModuleTitle}"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="Black"
                                       VerticalAlignment="Center"/>
                            
                        </StackPanel>

                        <Button Content="+ Add"
                                Style="{StaticResource Managebtn}"
                                Background="#0B4268"
                                Command="{Binding AddModeCommand}"
                                Margin="0,0,0,8"/>

                        <Button Content="Manage"
                                Style="{StaticResource Managebtn}"
                                Background="#0B4268"
                                Command="{Binding ManageModeCommand}"
                                Margin="0,0,0,8"/>

                        <Button Content="View"
                                Style="{StaticResource Managebtn}"
                                Background="#0B4268"
                                Command="{Binding ViewModeCommand}"/>

                        <Border Background="#05263D"
                                Padding="10"
                                Margin="0,24,0,0">
                            <StackPanel>
                                <TextBlock Text="Current Mode"
                                           Foreground="White"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Margin="0,0,0,5"/>

                                <TextBlock Text="{Binding CurrentMode}"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="Black"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="#2C2C2C"
                        BorderBrush="#2C2C2C"
                        BorderThickness="0"
                        Padding="6"
                        Margin="0">

                    <ContentControl Content="{Binding CurrentAdminDonationView}"/>
                </Border>
            </Grid>

        </Grid>
    </Viewbox>
</Window>