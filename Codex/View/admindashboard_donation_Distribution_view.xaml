<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_donation_Distribution_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="490"
             Background="Transparent">

    <Grid Background="#2C2C2C" Margin="0,0,0,0">

        <Grid.RowDefinitions>
            <!-- Distribution section -->
            <RowDefinition Height="28"/>   <!-- 0: "Distribution" header -->
            <RowDefinition Height="34"/>   <!-- 1: filter + search -->
            <RowDefinition Height="24"/>   <!-- 2: column headers -->
            <RowDefinition Height="78"/>   <!-- 3: data grid -->
            <!-- Distribution Items section -->
            <RowDefinition Height="26"/>   <!-- 4: "Distribution Items" header -->
            <RowDefinition Height="34"/>   <!-- 5: filter + search -->
            <RowDefinition Height="24"/>   <!-- 6: column headers -->
            <RowDefinition Height="70"/>   <!-- 7: data grid -->
            <!-- Add panels (visible only in Add mode) -->
            <RowDefinition Height="Auto"/> <!-- 8: New Distribution panel -->
            <RowDefinition Height="Auto"/> <!-- 9: Add Item panel -->
            <!-- Bottom action bar -->
            <RowDefinition Height="34"/>   <!-- 10: SAVE / UPDATE / DELETE -->
        </Grid.RowDefinitions>

        <!-- ── Distribution ──────────────────────────────────────────────── -->
        <TextBlock Grid.Row="0" Text="Distribution" Style="{StaticResource TableH1}"/>

        <Grid Grid.Row="1" Margin="8,0,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource Combo1}"
                      SelectedIndex="0"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding SelectedDistributionFilter}">
                <ComboBoxItem Content="Filter"/>
                <ComboBoxItem Content="All Distribution"/>
                <ComboBoxItem Content="Ongoing"/>
                <ComboBoxItem Content="Completed"/>
                <ComboBoxItem Content="Cancelled"/>
            </ComboBox>

            <Border Grid.Column="2" Height="26" Background="White">
                <Grid>
                    <TextBox Text="{Binding DistributionSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Searchbox}"/>
                    <TextBlock Text="Search" Style="{StaticResource Search}"/>
                    <Viewbox Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Canvas Width="18" Height="18">
                            <Ellipse Style="{StaticResource Ellipse1}"/>
                            <Path Data="M10,10 L16,16" Style="{StaticResource Path1}"/>
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#D9D9D9" Margin="8,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Distribution ID"       Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="1" Text="Beneficiary"           Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="2" Text="Event"                 Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="3" Text="Distribution Location" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="4" Text="Date Distributed"      Style="{StaticResource TableSub1}"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="White" Margin="8,0,8,0" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Distributions}"
                      SelectedItem="{Binding SelectedDistribution}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Style="{StaticResource Table}">
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding DistributionId}"       Width="1.1*" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding Beneficiary}"          Width="1.1*" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding Event}"                Width="1*"   IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding DistributionLocation}" Width="1.3*" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding DateDistributed, StringFormat=yyyy-MM-dd}" Width="1.2*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ── Distribution Items ────────────────────────────────────────── -->
        <TextBlock Grid.Row="4" Text="Distribution Items" Style="{StaticResource TableH1}"/>

        <Grid Grid.Row="5" Margin="8,0,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource Combo1}"
                      SelectedIndex="0"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding SelectedDistributionItemFilter}">
                <ComboBoxItem Content="Filter"/>
                <ComboBoxItem Content="All Items"/>
                <ComboBoxItem Content="Food"/>
                <ComboBoxItem Content="Water"/>
                <ComboBoxItem Content="Clothing"/>
                <ComboBoxItem Content="Medical"/>
            </ComboBox>

            <Border Grid.Column="2" Height="26" Background="White">
                <Grid>
                    <TextBox Text="{Binding DistributionItemSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Searchbox}"/>
                    <TextBlock Text="Search" Style="{StaticResource Search}"/>
                    <Viewbox Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Canvas Width="18" Height="18">
                            <Ellipse Style="{StaticResource Ellipse1}"/>
                            <Path Data="M10,10 L16,16" Style="{StaticResource Path1}"/>
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="6" Background="#D9D9D9" Margin="8,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Dist. Item ID"   Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="1" Text="Distribution ID" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="2" Text="Inventory Item"  Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="3" Text="Quantity"        Style="{StaticResource TableSub1}"/>
            </Grid>
        </Border>

        <Border Grid.Row="7" Background="White" Margin="8,0,8,0" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding DistributionItems}"
                      SelectedItem="{Binding SelectedDistributionItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Style="{StaticResource Table}">
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding DistributionItemId}" Width="1.2*" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding DistributionId}"     Width="1.1*" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding InventoryItem}"      Width="1.4*" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding Quantity}"           Width="1*"   IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ── New Distribution Add Panel ───────────────────────────────── -->
        <Border Grid.Row="8"
                Background="#1e3a52"
                Padding="8,6"
                Visibility="{Binding DropdownPanelVisibility}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="New Distribution" Foreground="White"
                           FontWeight="Bold" FontSize="11"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock Text="Beneficiary" Foreground="White" FontSize="10" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding BeneficiaryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="White" Height="24"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,4,0">
                        <TextBlock Text="Event" Foreground="White" FontSize="10" Margin="0,0,0,2"/>
                        <ComboBox ItemsSource="{Binding AvailableEvents}"
                                  SelectedItem="{Binding SelectedEventDropdown, Mode=TwoWay}"
                                  DisplayMemberPath="Display" Height="24"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,4,0">
                        <TextBlock Text="Location" Foreground="White" FontSize="10" Margin="0,0,0,2"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="22"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding AvailableLocations}"
                                      SelectedItem="{Binding SelectedLocationDropdown, Mode=TwoWay}"
                                      DisplayMemberPath="Display" Height="24"/>
                            <Button Grid.Column="1" Content="+" Width="22" Height="24"
                                    Command="{Binding AddNewLocationCommand}"
                                    ToolTip="Add new location" FontWeight="Bold" VerticalAlignment="Bottom"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,4,0">
                        <TextBlock Text="Date Distributed" Foreground="White" FontSize="10" Margin="0,0,0,2"/>
                        <DatePicker SelectedDate="{Binding NewDistributionDate, Mode=TwoWay}"
                                    Height="24"/>
                    </StackPanel>

                    <Button Grid.Column="4" Content="SAVE DISTRIB."
                            VerticalAlignment="Bottom"
                            Style="{StaticResource CRUDbtn}"
                            Command="{Binding SaveCommand}"
                            Width="90"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Add Distribution Item Panel ──────────────────────────────── -->
        <Border Grid.Row="9"
                Background="#2a3d4f"
                Padding="8,6"
                Visibility="{Binding DropdownPanelVisibility}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <TextBlock Text="Inventory Item (select to add — quantity validated against stock)"
                               Foreground="White" FontSize="10" Margin="0,0,0,2"/>
                    <ComboBox ItemsSource="{Binding AvailableInventory}"
                              SelectedItem="{Binding SelectedInventoryDropdown, Mode=TwoWay}"
                              DisplayMemberPath="Display" Height="24"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,6,0">
                    <TextBlock Text="Quantity" Foreground="White" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding PendingItemQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Background="White" Height="24"/>
                </StackPanel>

                <Button Grid.Column="2" Content="ADD ITEM"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource CRUDbtn}"
                        Command="{Binding AddDistributionItemCommand}"
                        Width="80"
                        ToolTip="Select a Distribution row first, then select inventory item and quantity"/>
            </Grid>
        </Border>

        <!-- ── Bottom action bar ─────────────────────────────────────────── -->
        <Grid Grid.Row="10"
              Background="#7F7F7F"
              Margin="8,0,8,0"
              Visibility="{Binding ActionButtonsVisibility}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">
                <Button Content="UPDATE" Style="{StaticResource CRUDbtn}" Command="{Binding UpdateCommand}"/>
                <Button Content="DELETE" Style="{StaticResource CRUDbtn}" Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
