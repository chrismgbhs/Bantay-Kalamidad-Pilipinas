<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.donationdashboard_AboutUs_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C"
          ClipToBounds="True">

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="560"
                    Margin="0,16,0,16">

            <TextBlock Text="About Us"
                       FontSize="20"
                       Style="{StaticResource Heading1}"
                       Margin="0,0,0,16"/>

            <TextBlock Text="About Bantay Kalamidad Pilipinas"
                       Style="{StaticResource Heading1}"
                       Margin="0,0,0,5"/>

            <TextBlock Text="Bantay Kalamidad Pilipinas is a non-profit disaster response and relief coordination organization focused on organizing rescue operations, donation tracking, inventory monitoring, and relief distribution through a centralized system."
                       Style="{StaticResource SubHeading1}"
                       Margin="0,0,0,18"/>

            <TextBlock Text="Mission"
                       Style="{StaticResource Heading1}"
                       Margin="0,0,0,5"/>

            <TextBlock Text="To improve disaster response coordination by providing volunteers, donors, and administrators with an organized platform for managing rescue operations, donations, inventories, and relief distribution."
                       Style="{StaticResource SubHeading1}"
                       Margin="0,0,0,18"/>

            <TextBlock Text="Vision"
                       Style="{StaticResource Heading1}"
                       Margin="0,0,0,5"/>

            <TextBlock Text="To become a reliable disaster response support system that strengthens preparedness, transparency, and community resilience during emergencies."
                       Style="{StaticResource SubHeading1}"
                       Margin="0,0,0,18"/>

            <TextBlock Text="How the System Works"
                       Style="{StaticResource Heading1}"
                       Margin="0,0,0,5"/>

            <TextBlock Text="The system connects Rescue Volunteers, Donors, and Administrators through role-based portals. Volunteers view assigned rescue operations, donors track pledges and donations, and administrators manage operations, inventory, logistics, and distribution records."
                       Style="{StaticResource SubHeading1}"/>

        </StackPanel>

    </Grid>
</UserControl>