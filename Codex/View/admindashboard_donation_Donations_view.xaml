<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_donation_Donations_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C"
          Margin="0,0,0,10">

        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="82"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Donations"
                   Style="{StaticResource TableH1}"/>

        <Grid Grid.Row="1"
              Margin="8,0,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource Combo1}"
                      VerticalAlignment="Bottom"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding SelectedDonationFilter}">
                <ComboBoxItem Content="Filter"/>
                <ComboBoxItem Content="All Donations"/>
                <ComboBoxItem Content="Pending"/>
                <ComboBoxItem Content="Received"/>
                <ComboBoxItem Content="Completed"/>
            </ComboBox>

            <Border Grid.Column="2"
                    Height="26"
                    Background="White"
                    VerticalAlignment="Bottom">
                <Grid>
                    <TextBox Text="{Binding DonationSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Searchbox}"/>

                    <TextBlock Text="Search"
                               Style="{StaticResource Search}"/>

                    <Viewbox Width="14"
                             Height="14"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0">
                        <Canvas Width="18" Height="18">
                            <Ellipse Style="{StaticResource Ellipse1}"/>
                            <Path Data="M10,10 L16,16" Style="{StaticResource Path1}"/>
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#D9D9D9"
                Margin="8,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.25*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Donation ID" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="1" Text="Donor" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="2" Text="Event" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="3" Text="Date Received" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="4" Text="Status" Style="{StaticResource TableSub1}"/>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                Margin="8,0,8,0"
                ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Donations}"
                      SelectedItem="{Binding SelectedDonation}"
                      AutoGenerateColumns="False"
                      Style="{StaticResource Table}">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <!-- ID: auto-generated, read-only -->
                    <DataGridTextColumn Binding="{Binding DonationId}" Width="1.1*" IsReadOnly="True"/>

                    <!-- Donor: ComboBox in cell -->
                    <DataGridTemplateColumn Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Donor}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableDonors, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          SelectedItem="{Binding DataContext.SelectedDonorDropdown, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay}"
                                          DisplayMemberPath="Display" BorderThickness="0" Background="White"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Event: ComboBox in cell -->
                    <DataGridTemplateColumn Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Event}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableEvents, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          SelectedItem="{Binding DataContext.SelectedEventDropdown, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay}"
                                          DisplayMemberPath="Display" BorderThickness="0" Background="White"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Date Received: DatePicker -->
                    <DataGridTemplateColumn Width="1.25*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DateReceived, StringFormat=yyyy-MM-dd}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding DateReceived, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            BorderThickness="0" Background="Transparent"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status: read-only computed column -->
                    <DataGridTextColumn Binding="{Binding Status}" Width="1*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="4"
                   Text="Donated Items"
                   Style="{StaticResource TableH1}"/>

        <Grid Grid.Row="5"
              Margin="8,0,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource Combo1}"
                      VerticalAlignment="Bottom"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding SelectedDonatedItemFilter}">
                <ComboBoxItem Content="Filter"/>
                <ComboBoxItem Content="All Items"/>
                <ComboBoxItem Content="Food"/>
                <ComboBoxItem Content="Water"/>
                <ComboBoxItem Content="Clothing"/>
                <ComboBoxItem Content="Medical"/>
            </ComboBox>

            <Border Grid.Column="2"
                    Height="26"
                    Background="White"
                    VerticalAlignment="Bottom">
                <Grid>
                    <TextBox Text="{Binding DonatedItemSearchText, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource Searchbox}"/>

                    <TextBlock Text="Search"
                               Style="{StaticResource Search}"/>

                    <Viewbox Width="14"
                             Height="14"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0">
                        <Canvas Width="18" Height="18">
                            <Ellipse Style="{StaticResource Ellipse1}"/>
                            <Path Data="M10,10 L16,16" Style="{StaticResource Path1}"/>
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="6"
                Background="#D9D9D9"
                Margin="8,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Donated Item ID" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="1" Text="Donation ID" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="2" Text="Item Name" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="3" Text="Quantity" Style="{StaticResource TableSub1}"/>
            </Grid>
        </Border>

        <Border Grid.Row="7"
                Background="White"
                Margin="8,0,8,0"
                ClipToBounds="True">
            <DataGrid ItemsSource="{Binding DonatedItems}"
                      SelectedItem="{Binding SelectedDonatedItem}"
                      AutoGenerateColumns="False"
                      Style="{StaticResource Table}">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding DonatedItemId}" Width="1.2*"/>
                    <DataGridTextColumn Binding="{Binding DonationId}" Width="1.1*"/>
                    <DataGridTextColumn Binding="{Binding ItemName}" Width="1.4*"/>
                    <DataGridTextColumn Binding="{Binding Quantity}" Width="1*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="8"
              Background="#7F7F7F"
              Margin="8,0,8,0"
              Visibility="{Binding ActionButtonsVisibility}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">

                <Button Content="SAVE" 
                        Style="{StaticResource CRUDbtn}" 
                        Command="{Binding SaveCommand}"/>

                <Button Content="UPDATE" 
                        Style="{StaticResource CRUDbtn}" 
                        Command="{Binding UpdateCommand}"/>

                <Button Content="DELETE" 
                        Style="{StaticResource CRUDbtn}" 
                        Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>