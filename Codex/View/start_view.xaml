<Window x:Class="Bantay_Kalamidad_Pilipinas.View.start_view"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Start"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="CanResize">

    <Viewbox Stretch="Uniform">
        <Grid Width="1100" Height="750">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <Image Source="/Images/bkp_logo.png"
                       Width="220"
                       Height="220"
                       Stretch="Uniform"
                       Margin="0,0,0,20"/>

                <TextBlock Text="Bantay Kalamidad Pilipinas"
                           FontSize="30"
                           FontWeight="Black"
                           Foreground="Black"
                           TextAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Disaster Response and Relief Coordination System"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="Black"
                           TextAlignment="Center"
                           Margin="0,0,0,50"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,70">

                    <Button Content="RESCUE"
                            Width="240"
                            Height="65"
                            Background="{StaticResource RescuePrimary}"
                            BorderBrush="{StaticResource RescueSecond}"
                            BorderThickness="3"
                            Foreground="White"
                            FontSize="18"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Command="{Binding OpenRescueCommand}"
                            Margin="0,0,80,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="DONATION"
                            Width="240"
                            Height="65"
                            Background="{StaticResource DonorPrimary}"
                            BorderBrush="{StaticResource DonorSecond}"
                            BorderThickness="3"
                            Foreground="White"
                            FontSize="18"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Command="{Binding OpenDonationCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>

                <Button Content="ADMIN"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource AdminPrimary}"
                        FontSize="20"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Command="{Binding OpenAdminCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{TemplateBinding Content}"
                                       TextDecorations="Underline"
                                       HorizontalAlignment="Center"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>

        </Grid>
    </Viewbox>
</Window>