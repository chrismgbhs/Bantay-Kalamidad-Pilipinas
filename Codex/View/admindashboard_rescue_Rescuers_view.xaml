<UserControl x:Class="Bantay_Kalamidad_Pilipinas.View.admindashboard_rescue_Rescuers_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="700"
             Height="430"
             Background="Transparent">

    <Grid Background="#2C2C2C">

        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="8"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Rescuers"
                   FontSize="18"
                   Style="{StaticResource TableH1}"/>

        <Grid Grid.Row="1"
              Margin="8,0,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource Combo1}"
                      VerticalAlignment="Bottom"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding SelectedRescuerFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ComboBoxItem Content="All Rescuers"/>
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="Inactive"/>
                <ComboBoxItem Content="Assigned"/>
            </ComboBox>

            <Border Grid.Column="2"
                    Height="28"
                    Background="White"
                    VerticalAlignment="Bottom">
                <Grid>
                    <TextBox Text="{Binding RescuerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Searchbox}"/>

                    <TextBlock Text="Search"
                               Style="{StaticResource Search}"/>

                    <Viewbox Width="15"
                             Height="15"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0">
                        <Canvas Width="18" Height="18">
                            <Ellipse Style="{StaticResource Ellipse1}"/>
                            <Path Data="M10,10 L16,16" Style="{StaticResource Path1}"/>
                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#D9D9D9"
                Margin="8,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Rescuer ID" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="1" Text="Name" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="2" Text="Contact Number" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="3" Text="User ID" Style="{StaticResource TableSub1}"/>
                <TextBlock Grid.Column="4" Text="Status" Style="{StaticResource TableSub1}"/>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                Margin="8,0,8,0"
                ClipToBounds="True">

            <DataGrid ItemsSource="{Binding Rescuers}"
                      SelectedItem="{Binding SelectedRescuer, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="None"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="{Binding IsTableReadOnly}"
                      Style="{StaticResource Table}">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding RescuerId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.1*"/>
                    <DataGridTextColumn Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.1*"/>
                    <DataGridTextColumn Binding="{Binding ContactNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.4*"/>
                    <DataGridTextColumn Binding="{Binding UserId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1*"/>
                    <DataGridTextColumn Binding="{Binding Status}" Width="1*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="4"
              Background="#7F7F7F"
              Margin="8,0,8,0"
              Visibility="{Binding ActionButtonsVisibility}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">

                <Button Content="SAVE"
                        Style="{StaticResource CRUDbtn}"
                        Command="{Binding SaveCommand}"/>

                <Button Content="UPDATE"
                        Style="{StaticResource CRUDbtn}"
                        Command="{Binding UpdateCommand}"/>

                <Button Content="DELETE"
                        Style="{StaticResource CRUDbtn}"
                        Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>